<UserControl
    x:Class="LinuxCloth.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LinuxCloth.Desktop.Controls"
    Background="{DynamicResource AppBackgroundBrush}"
    KeyDown="OnKeyDown">
  <!-- Layout modeled on TableCloth CatalogPage: category radios, instruction + search, icon grid. -->
  <UserControl.Styles>
    <Style Selector="ListBox.category-list">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.category-list > ListBoxItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="Margin" Value="4,2" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="ListBox.category-list > ListBoxItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
    </Style>
    <Style Selector="ListBox.category-list > ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.category-list > ListBoxItem:selected TextBlock.category-label">
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="ListBox.category-list > ListBoxItem:selected Ellipse.category-radio">
      <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Stroke" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="ListBox.service-grid">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.service-grid > ListBoxItem">
      <Setter Property="Width" Value="78" />
      <Setter Property="MinHeight" Value="96" />
      <Setter Property="Padding" Value="4,4" />
      <Setter Property="Margin" Value="5" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Top" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.service-grid > ListBoxItem:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource SelectionBorderBrush}" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.service-grid > ListBoxItem:selected">
      <Setter Property="BorderBrush" Value="{DynamicResource SelectionBorderBrush}" />
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto">
    <!-- Compact: title + search + category combo (TableCloth-like utility chrome) -->
    <Border
        x:Name="CompactHeader"
        Grid.Row="0"
        IsVisible="False"
        Background="{DynamicResource SurfaceRaisedBrush}"
        BorderBrush="{DynamicResource BorderSubtleBrush}"
        BorderThickness="0,0,0,1"
        Padding="8,6">
      <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
          <TextBlock Text="linuxcloth" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
          <Border Grid.Column="1" Classes="badge-neutral" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <Ellipse Width="7" Height="7" Fill="{DynamicResource SuccessBrush}" IsVisible="{Binding IsReady}" />
              <Ellipse Width="7" Height="7" Fill="{DynamicResource WarningBrush}" IsVisible="{Binding !IsReady}" />
              <TextBlock Text="{Binding DoctorSummary}" FontSize="11" />
            </StackPanel>
          </Border>
          <Button
              Grid.Column="2"
              Classes="secondary"
              Content="환경"
              Click="OnOpenImageSetup"
              IsEnabled="{Binding CanConfigureImages}"
              AutomationProperties.AutomationId="Catalog.WindowsEnvironment.Compact"
              AutomationProperties.Name="Windows 환경 관리" />
        </Grid>
        <Grid Grid.Row="1" ColumnDefinitions="*,140" ColumnSpacing="6">
          <Border Classes="search-field">
            <TextBox
                x:Name="CompactSearchBox"
                Classes="search"
                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="검색 키워드 입력"
                AutomationProperties.AutomationId="Catalog.Search.Compact"
                AutomationProperties.Name="서비스 검색" />
          </Border>
          <ComboBox
              Grid.Column="1"
              ItemsSource="{Binding Categories}"
              SelectedItem="{Binding SelectedCategory}"
              HorizontalContentAlignment="Stretch"
              AutomationProperties.AutomationId="Catalog.Category.Compact"
              AutomationProperties.Name="서비스 분류">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </Grid>
      </Grid>
    </Border>

    <!-- Desktop: thin utility bar (status + environment). Search sits with catalog like TableCloth. -->
    <Border
        x:Name="DesktopHeader"
        Grid.Row="0"
        Background="{DynamicResource SurfaceRaisedBrush}"
        BorderBrush="{DynamicResource BorderSubtleBrush}"
        BorderThickness="0,0,0,1"
        Padding="8,6">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <TextBlock Text="linuxcloth" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" />
        </StackPanel>
        <Border Grid.Column="1" />
        <Button
            x:Name="ReadinessButton"
            Grid.Column="2"
            Classes="secondary"
            Padding="10,4"
            AutomationProperties.AutomationId="Catalog.Readiness"
            AutomationProperties.Name="실행 준비 상태">
          <Button.Flyout>
            <Flyout Placement="BottomEdgeAlignedRight">
              <Border Classes="card" Width="340" Padding="12">
                <StackPanel Spacing="10">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" IsVisible="{Binding IsReady}" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource WarningBrush}" IsVisible="{Binding !IsReady}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding DoctorSummary}" FontWeight="Bold" />
                  </StackPanel>
                  <Button
                      Classes="secondary"
                      Content="다시 확인"
                      Command="{Binding RefreshDoctorCommand}"
                      HorizontalAlignment="Left"
                      AutomationProperties.AutomationId="Catalog.Readiness.Refresh" />
                  <Expander
                      Classes="technical"
                      Header="기술 세부정보"
                      AutomationProperties.AutomationId="Catalog.Readiness.TechnicalDetails">
                    <ItemsControl ItemsSource="{Binding DoctorChecks}" Margin="0,6,0,0">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="20,100,*" Margin="0,3">
                            <TextBlock Text="{Binding Status}" FontWeight="Bold" />
                            <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="12" />
                            <TextBlock Grid.Column="2" Text="{Binding Detail}" Classes="muted" TextWrapping="Wrap" FontSize="11" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Expander>
                </StackPanel>
              </Border>
            </Flyout>
          </Button.Flyout>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" IsVisible="{Binding IsReady}" />
            <Ellipse Width="8" Height="8" Fill="{DynamicResource WarningBrush}" IsVisible="{Binding !IsReady}" />
            <TextBlock Text="{Binding DoctorSummary}" FontSize="12" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button
            Grid.Column="3"
            Classes="secondary"
            Content="Windows 환경"
            Click="OnOpenImageSetup"
            IsEnabled="{Binding CanConfigureImages}"
            AutomationProperties.AutomationId="Catalog.WindowsEnvironment"
            AutomationProperties.Name="Windows 환경 관리" />
      </Grid>
    </Border>

    <Grid x:Name="ContentGrid" Grid.Row="1" ColumnDefinitions="150,*,320">
      <!-- Category rail: RadioButton-like list -->
      <Border
          x:Name="CategoryRail"
          Grid.Column="0"
          Background="{DynamicResource AppBackgroundBrush}"
          BorderBrush="{DynamicResource BorderSubtleBrush}"
          BorderThickness="0,0,1,0"
          Padding="2,8,2,8">
        <Grid RowDefinitions="*,Auto">
          <ListBox
              Grid.Row="0"
              Classes="category-list"
              ItemsSource="{Binding Categories}"
              SelectedItem="{Binding SelectedCategory}"
              AutomationProperties.AutomationId="Catalog.Categories"
              AutomationProperties.Name="서비스 분류">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Ellipse
                      Classes="category-radio"
                      Width="12"
                      Height="12"
                      Stroke="{DynamicResource TextSecondaryBrush}"
                      StrokeThickness="1"
                      Fill="Transparent"
                      VerticalAlignment="Center" />
                  <TextBlock Classes="category-label" Text="{Binding Label}" FontSize="13" VerticalAlignment="Center" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <StackPanel Grid.Row="1" Margin="8,8,8,4" Spacing="6">
            <TextBlock Text="Windows 환경" Classes="muted" FontSize="11" />
            <ComboBox
                ItemsSource="{Binding Images}"
                SelectedItem="{Binding SelectedImage}"
                HorizontalAlignment="Stretch"
                AutomationProperties.AutomationId="Catalog.WindowsEnvironment.Select"
                AutomationProperties.Name="Windows 환경 선택">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button
                Classes="secondary"
                Content="환경 관리"
                Click="OnOpenImageSetup"
                IsEnabled="{Binding CanConfigureImages}"
                AutomationProperties.AutomationId="Catalog.WindowsEnvironment.Manage"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Catalog: instruction + search + icon grid -->
      <Grid x:Name="ServicesContent" Grid.Column="1" RowDefinitions="Auto,Auto,*" Margin="0">
        <Grid Grid.Row="0" ColumnDefinitions="*,220" MinHeight="45" Margin="8,4,8,0">
          <TextBlock
              VerticalAlignment="Center"
              Margin="0,0,8,0"
              FontWeight="Bold"
              TextWrapping="Wrap"
              FontSize="13"
              Text="접속하려는 사이트를 선택하거나, 검색창에서 검색어를 입력하세요." />
          <Border Grid.Column="1" Classes="search-field" VerticalAlignment="Center" Margin="0,6">
            <Grid ColumnDefinitions="Auto,*" Margin="6,0">
              <PathIcon
                  Width="14"
                  Height="14"
                  Margin="0,0,4,0"
                  Foreground="{DynamicResource TextSecondaryBrush}"
                  Data="{StaticResource IconSearch}"
                  VerticalAlignment="Center" />
              <TextBox
                  x:Name="DesktopSearchBox"
                  Grid.Column="1"
                  Classes="search"
                  Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                  PlaceholderText="검색 키워드 입력"
                  AutomationProperties.AutomationId="Catalog.Search"
                  AutomationProperties.Name="서비스 검색"
                  AutomationProperties.HelpText="서비스 이름으로 카탈로그를 검색합니다." />
            </Grid>
          </Border>
        </Grid>

        <Grid
            x:Name="AdaptiveFilterBar"
            Grid.Row="1"
            IsVisible="False"
            Margin="8,0,8,4"
            ColumnDefinitions="Auto,*">
          <TextBlock Text="분류" VerticalAlignment="Center" Margin="0,0,8,0" Classes="muted" />
          <ComboBox
              Grid.Column="1"
              MaxWidth="220"
              HorizontalAlignment="Left"
              ItemsSource="{Binding Categories}"
              SelectedItem="{Binding SelectedCategory}"
              AutomationProperties.AutomationId="Catalog.Category.Medium"
              AutomationProperties.Name="서비스 분류">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </Grid>

        <ListBox
            x:Name="ServicesList"
            Grid.Row="2"
            Classes="service-grid"
            ItemsSource="{Binding FilteredServices}"
            SelectedItem="{Binding SelectedService}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            Margin="4,0,4,4"
            AutomationProperties.AutomationId="Catalog.Services"
            AutomationProperties.Name="서비스 목록">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <!-- Icon + caption, matching TableCloth FileItemStyle -->
              <Grid Width="64" MinHeight="88" VerticalAlignment="Top">
                <Grid.RowDefinitions>
                  <RowDefinition Height="48" />
                  <RowDefinition Height="2" />
                  <RowDefinition Height="Auto" MinHeight="38" />
                </Grid.RowDefinitions>
                <Image
                    Grid.Row="0"
                    Source="{Binding Image}"
                    Width="48"
                    Height="48"
                    Stretch="Uniform"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
                <TextBlock
                    Grid.Row="2"
                    Text="{Binding DisplayName}"
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                    FontSize="11"
                    MaxHeight="46"
                    TextTrimming="CharacterEllipsis"
                    VerticalAlignment="Top" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <!-- Detail inspector (TableCloth DetailPage-inspired, kept as side panel) -->
      <Border
          x:Name="WideDetailsPanel"
          Grid.Column="2"
          Background="{DynamicResource SurfaceRaisedBrush}"
          BorderBrush="{DynamicResource BorderSubtleBrush}"
          BorderThickness="1,0,0,0"
          Padding="12">
        <Grid>
          <StackPanel
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Spacing="6"
              Margin="12"
              IsVisible="{Binding !HasSelectedService}">
            <TextBlock
                Text="사이트를 선택하세요"
                Classes="muted"
                FontSize="13"
                HorizontalAlignment="Center" />
          </StackPanel>
          <controls:ServiceDetails IsVisible="{Binding HasSelectedService}" />
        </Grid>
      </Border>
    </Grid>

    <!-- Flat status strip -->
    <Border
        Grid.Row="2"
        Background="{DynamicResource SurfaceBrush}"
        BorderBrush="{DynamicResource BorderSubtleBrush}"
        BorderThickness="0,1,0,0"
        Padding="8,5">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8" VerticalAlignment="Center">
        <ProgressBar
            Grid.Column="0"
            Width="80"
            Height="4"
            IsIndeterminate="True"
            IsVisible="{Binding IsBusy}"
            AutomationProperties.Name="작업 진행 중" />
        <TextBlock
            Grid.Column="1"
            Text="{Binding SessionStatus}"
            VerticalAlignment="Center"
            FontSize="12"
            TextTrimming="CharacterEllipsis"
            AutomationProperties.LiveSetting="Polite" />
        <TextBlock
            Grid.Column="2"
            Text="{Binding ErrorMessage}"
            Classes="danger"
            FontSize="12"
            IsVisible="{Binding HasError}"
            TextTrimming="CharacterEllipsis"
            MaxWidth="360"
            AutomationProperties.LiveSetting="Assertive" />
        <Button
            Grid.Column="3"
            Classes="danger"
            Content="닫고 삭제"
            Command="{Binding StopCommand}"
            IsVisible="{Binding IsSessionRunning}"
            AutomationProperties.AutomationId="Catalog.Session.Stop"
            AutomationProperties.Name="Windows 환경 닫기 및 삭제" />
      </Grid>
    </Border>

    <!-- Details overlay for medium/compact -->
    <Border
        x:Name="DetailsOverlay"
        Grid.RowSpan="3"
        IsVisible="False"
        Background="{DynamicResource ScrimBrush}"
        ZIndex="20">
      <Border
          x:Name="DetailsDrawer"
          Background="{DynamicResource SurfaceRaisedBrush}"
          BorderBrush="{DynamicResource BorderSubtleBrush}"
          BorderThickness="1"
          Width="400"
          MaxWidth="400"
          Margin="0"
          Padding="12"
          HorizontalAlignment="Right"
          VerticalAlignment="Stretch">
        <Grid RowDefinitions="Auto,*">
          <Button
              Grid.Row="0"
              Classes="ghost icon-sm"
              HorizontalAlignment="Left"
              Click="OnCloseDetails"
              AutomationProperties.AutomationId="Catalog.Details.Close"
              AutomationProperties.Name="서비스 상세정보 닫기">
            <PathIcon Width="16" Height="16" Data="{StaticResource IconClose}" />
          </Button>
          <controls:ServiceDetails Grid.Row="1" />
        </Grid>
      </Border>
    </Border>
  </Grid>
</UserControl>
