<UserControl
    x:Class="LinuxCloth.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LinuxCloth.Desktop.Controls"
    Background="{DynamicResource AppBackgroundBrush}"
    KeyDown="OnKeyDown">
  <Grid RowDefinitions="Auto,*,Auto">
    <!-- Compact header -->
    <Border
        x:Name="CompactHeader"
        Grid.Row="0"
        IsVisible="False"
        Classes="chrome-bar"
        Padding="12,10">
      <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
          <TextBlock Text="linuxcloth" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
          <Border Grid.Column="1" Classes="badge-success" VerticalAlignment="Center" IsVisible="{Binding IsReady}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <PathIcon
                  Width="12"
                  Height="12"
                  Foreground="{DynamicResource SuccessBrush}"
                  Data="{StaticResource IconCheckCircle}"
                  VerticalAlignment="Center" />
              <TextBlock Text="{Binding DoctorSummary}" Classes="meta" Foreground="{DynamicResource SuccessBrush}" />
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Classes="badge-warning" VerticalAlignment="Center" IsVisible="{Binding !IsReady}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <PathIcon
                  Width="12"
                  Height="12"
                  Foreground="{DynamicResource WarningBrush}"
                  Data="{StaticResource IconAlert}"
                  VerticalAlignment="Center" />
              <TextBlock Text="{Binding DoctorSummary}" Classes="meta" Foreground="{DynamicResource WarningBrush}" />
            </StackPanel>
          </Border>
          <Button
              Grid.Column="2"
              Classes="secondary"
              Content="환경"
              Click="OnOpenImageSetup"
              IsEnabled="{Binding CanConfigureImages}"
              AutomationProperties.AutomationId="Catalog.WindowsEnvironment.Compact"
              AutomationProperties.Name="Windows 환경 관리" />
        </Grid>
        <Grid Grid.Row="1" ColumnDefinitions="*,140" ColumnSpacing="6">
          <Border Classes="search-field">
            <Grid ColumnDefinitions="Auto,*" Margin="8,0">
              <PathIcon
                  Width="14"
                  Height="14"
                  Margin="0,0,4,0"
                  Foreground="{DynamicResource TextSecondaryBrush}"
                  Data="{StaticResource IconSearch}"
                  VerticalAlignment="Center" />
              <TextBox
                  x:Name="CompactSearchBox"
                  Grid.Column="1"
                  Classes="search"
                  Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                  PlaceholderText="서비스 검색"
                  AutomationProperties.AutomationId="Catalog.Search.Compact"
                  AutomationProperties.Name="서비스 검색" />
            </Grid>
          </Border>
          <ComboBox
              Grid.Column="1"
              ItemsSource="{Binding Categories}"
              SelectedItem="{Binding SelectedCategory}"
              HorizontalContentAlignment="Stretch"
              AutomationProperties.AutomationId="Catalog.Category.Compact"
              AutomationProperties.Name="서비스 분류">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </Grid>
      </Grid>
    </Border>

    <!-- Desktop header -->
    <Border
        x:Name="DesktopHeader"
        Grid.Row="0"
        Classes="chrome-bar"
        Padding="16,10"
        BorderBrush="{DynamicResource BorderSubtleBrush}"
        BorderThickness="0,0,0,1"
        Background="{DynamicResource SurfaceRaisedBrush}">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
        <TextBlock Text="linuxcloth" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
        <Button
            x:Name="ReadinessButton"
            Grid.Column="2"
            Classes="ghost"
            Padding="8,4"
            VerticalAlignment="Center"
            AutomationProperties.AutomationId="Catalog.Readiness"
            AutomationProperties.Name="실행 준비 상태">
          <Button.Flyout>
            <Flyout Placement="BottomEdgeAlignedRight">
              <Border Classes="card" Width="340">
                <StackPanel Spacing="10">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon
                        Width="16"
                        Height="16"
                        Foreground="{DynamicResource SuccessBrush}"
                        Data="{StaticResource IconCheckCircle}"
                        IsVisible="{Binding IsReady}"
                        VerticalAlignment="Center" />
                    <PathIcon
                        Width="16"
                        Height="16"
                        Foreground="{DynamicResource WarningBrush}"
                        Data="{StaticResource IconAlert}"
                        IsVisible="{Binding !IsReady}"
                        VerticalAlignment="Center" />
                    <TextBlock Text="{Binding DoctorSummary}" FontWeight="SemiBold" VerticalAlignment="Center" />
                  </StackPanel>
                  <Button
                      Classes="secondary"
                      Content="다시 확인"
                      Command="{Binding RefreshDoctorCommand}"
                      HorizontalAlignment="Left"
                      AutomationProperties.AutomationId="Catalog.Readiness.Refresh" />
                  <Expander
                      Classes="technical"
                      Header="기술 세부정보"
                      AutomationProperties.AutomationId="Catalog.Readiness.TechnicalDetails">
                    <ItemsControl ItemsSource="{Binding DoctorChecks}" Margin="0,6,0,0">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="Auto,100,*" ColumnSpacing="8" Margin="0,4">
                            <PathIcon
                                Width="12"
                                Height="12"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource SuccessBrush}"
                                Data="{StaticResource IconCheck}"
                                IsVisible="{Binding IsAvailable}" />
                            <PathIcon
                                Width="12"
                                Height="12"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource WarningBrush}"
                                Data="{StaticResource IconAlert}"
                                IsVisible="{Binding !IsAvailable}" />
                            <TextBlock Grid.Column="1" Text="{Binding Label}" Classes="caption" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding Detail}" Classes="meta" TextWrapping="Wrap" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Expander>
                </StackPanel>
              </Border>
            </Flyout>
          </Button.Flyout>
          <Grid>
            <Border Classes="badge-success" IsVisible="{Binding IsReady}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon
                    Width="14"
                    Height="14"
                    Foreground="{DynamicResource SuccessBrush}"
                    Data="{StaticResource IconCheckCircle}"
                    VerticalAlignment="Center" />
                <TextBlock
                    Text="{Binding DoctorSummary}"
                    Classes="caption"
                    Foreground="{DynamicResource SuccessBrush}"
                    VerticalAlignment="Center" />
              </StackPanel>
            </Border>
            <Border Classes="badge-warning" IsVisible="{Binding !IsReady}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon
                    Width="14"
                    Height="14"
                    Foreground="{DynamicResource WarningBrush}"
                    Data="{StaticResource IconAlert}"
                    VerticalAlignment="Center" />
                <TextBlock
                    Text="{Binding DoctorSummary}"
                    Classes="caption"
                    Foreground="{DynamicResource WarningBrush}"
                    VerticalAlignment="Center" />
              </StackPanel>
            </Border>
          </Grid>
        </Button>
        <Button
            Grid.Column="3"
            Classes="secondary"
            Click="OnOpenImageSetup"
            IsEnabled="{Binding CanConfigureImages}"
            VerticalAlignment="Center"
            AutomationProperties.AutomationId="Catalog.WindowsEnvironment"
            AutomationProperties.Name="Windows 환경 관리">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <PathIcon Width="14" Height="14" Data="{StaticResource IconDesktop}" VerticalAlignment="Center" />
            <TextBlock Text="Windows 환경" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <Grid x:Name="ContentGrid" Grid.Row="1" ColumnDefinitions="168,*,340">
      <Border
          x:Name="CategoryRail"
          Grid.Column="0"
          Background="{DynamicResource SurfaceRaisedBrush}"
          BorderBrush="{DynamicResource BorderSubtleBrush}"
          BorderThickness="0,0,1,0"
          Padding="4,12,4,12">
        <Grid RowDefinitions="*,Auto">
          <ListBox
              Grid.Row="0"
              Classes="category-list"
              ItemsSource="{Binding Categories}"
              SelectedItem="{Binding SelectedCategory}"
              AutomationProperties.AutomationId="Catalog.Categories"
              AutomationProperties.Name="서비스 분류">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Ellipse
                      Classes="category-radio"
                      Width="14"
                      Height="14"
                      Stroke="{DynamicResource TextSecondaryBrush}"
                      StrokeThickness="1.5"
                      Fill="Transparent"
                      VerticalAlignment="Center" />
                  <TextBlock Classes="category-label body" Text="{Binding Label}" VerticalAlignment="Center" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <StackPanel Grid.Row="1" Margin="8,8,8,4" Spacing="6">
            <ComboBox
                ItemsSource="{Binding Images}"
                SelectedItem="{Binding SelectedImage}"
                HorizontalAlignment="Stretch"
                AutomationProperties.AutomationId="Catalog.WindowsEnvironment.Select"
                AutomationProperties.Name="Windows 환경 선택">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon
                        Width="14"
                        Height="14"
                        Data="{StaticResource IconDesktop}"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
        </Grid>
      </Border>

      <Grid x:Name="ServicesContent" Grid.Column="1" RowDefinitions="Auto,Auto,*" Margin="16,12,16,8">
        <StackPanel Grid.Row="0" Spacing="10">
          <TextBlock
              Classes="instruction"
              TextWrapping="Wrap"
              Text="접속하려는 사이트를 선택하거나, 검색창에서 검색어를 입력하세요." />
          <Border Classes="search-field">
            <Grid ColumnDefinitions="Auto,*" Margin="10,0">
              <PathIcon
                  Width="14"
                  Height="14"
                  Margin="0,0,6,0"
                  Foreground="{DynamicResource TextSecondaryBrush}"
                  Data="{StaticResource IconSearch}"
                  VerticalAlignment="Center" />
              <TextBox
                  x:Name="DesktopSearchBox"
                  Grid.Column="1"
                  Classes="search"
                  Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                  PlaceholderText="서비스 검색"
                  AutomationProperties.AutomationId="Catalog.Search"
                  AutomationProperties.Name="서비스 검색"
                  AutomationProperties.HelpText="서비스 이름으로 카탈로그를 검색합니다." />
            </Grid>
          </Border>
        </StackPanel>

        <Grid
            x:Name="AdaptiveFilterBar"
            Grid.Row="1"
            IsVisible="False"
            Margin="0,10,0,0"
            ColumnDefinitions="Auto,*">
          <TextBlock Text="분류" Classes="caption" VerticalAlignment="Center" Margin="0,0,8,0" />
          <ComboBox
              Grid.Column="1"
              MaxWidth="220"
              HorizontalAlignment="Left"
              ItemsSource="{Binding Categories}"
              SelectedItem="{Binding SelectedCategory}"
              AutomationProperties.AutomationId="Catalog.Category.Medium"
              AutomationProperties.Name="서비스 분류">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </Grid>

        <ListBox
            x:Name="ServicesList"
            Grid.Row="2"
            Classes="service-grid"
            ItemsSource="{Binding FilteredServices}"
            SelectedItem="{Binding SelectedService}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            Margin="0,8,0,0"
            AutomationProperties.AutomationId="Catalog.Services"
            AutomationProperties.Name="서비스 목록">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid Width="72" MinHeight="92" VerticalAlignment="Top">
                <Grid.RowDefinitions>
                  <RowDefinition Height="48" />
                  <RowDefinition Height="4" />
                  <RowDefinition Height="Auto" MinHeight="36" />
                </Grid.RowDefinitions>
                <Border
                    Grid.Row="0"
                    Classes="logo-frame"
                    Width="48"
                    Height="48"
                    Padding="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                  <Image
                      Source="{Binding Image}"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
                </Border>
                <TextBlock
                    Grid.Row="2"
                    Text="{Binding DisplayName}"
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                    Classes="meta"
                    MaxHeight="44"
                    TextTrimming="CharacterEllipsis"
                    VerticalAlignment="Top" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <Border
          x:Name="WideDetailsPanel"
          Grid.Column="2"
          Background="{DynamicResource SurfaceRaisedBrush}"
          BorderBrush="{DynamicResource BorderSubtleBrush}"
          BorderThickness="1,0,0,0"
          Padding="16">
        <Grid>
          <TextBlock
              Text="사이트를 선택하세요"
              Classes="caption"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              IsVisible="{Binding !HasSelectedService}" />
          <controls:ServiceDetails IsVisible="{Binding HasSelectedService}" />
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2" Classes="status-strip">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <ProgressBar
              Width="80"
              IsIndeterminate="True"
              IsVisible="{Binding IsBusy}"
              VerticalAlignment="Center"
              AutomationProperties.Name="작업 진행 중" />
          <PathIcon
              Width="14"
              Height="14"
              Foreground="{DynamicResource SuccessBrush}"
              Data="{StaticResource IconCheckCircle}"
              IsVisible="{Binding IsReady}"
              VerticalAlignment="Center" />
          <PathIcon
              Width="14"
              Height="14"
              Foreground="{DynamicResource WarningBrush}"
              Data="{StaticResource IconAlert}"
              IsVisible="{Binding !IsReady}"
              VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock
            Grid.Column="1"
            Text="{Binding SessionStatus}"
            Classes="caption"
            VerticalAlignment="Center"
            TextTrimming="CharacterEllipsis"
            AutomationProperties.LiveSetting="Polite" />
        <TextBlock
            Grid.Column="2"
            Text="{Binding ErrorMessage}"
            Classes="danger caption"
            IsVisible="{Binding HasError}"
            TextTrimming="CharacterEllipsis"
            MaxWidth="360"
            AutomationProperties.LiveSetting="Assertive" />
        <Button
            Grid.Column="3"
            Classes="danger"
            Content="닫고 삭제"
            Command="{Binding StopCommand}"
            IsVisible="{Binding IsSessionRunning}"
            AutomationProperties.AutomationId="Catalog.Session.Stop"
            AutomationProperties.Name="Windows 환경 닫기 및 삭제" />
      </Grid>
    </Border>

    <Border
        x:Name="DetailsOverlay"
        Grid.RowSpan="3"
        IsVisible="False"
        Background="{DynamicResource ScrimBrush}"
        ZIndex="20">
      <Border
          x:Name="DetailsDrawer"
          Background="{DynamicResource SurfaceRaisedBrush}"
          BorderBrush="{DynamicResource BorderSubtleBrush}"
          BorderThickness="1,0,0,0"
          Width="400"
          MaxWidth="400"
          Padding="16"
          HorizontalAlignment="Right"
          VerticalAlignment="Stretch">
        <Grid RowDefinitions="Auto,*">
          <Button
              Grid.Row="0"
              Classes="ghost"
              HorizontalAlignment="Left"
              Margin="0,0,0,8"
              Click="OnCloseDetails"
              AutomationProperties.AutomationId="Catalog.Details.Close"
              AutomationProperties.Name="서비스 상세정보 닫기">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <PathIcon Width="14" Height="14" Data="{StaticResource IconClose}" VerticalAlignment="Center" />
              <TextBlock Text="서비스 상세정보 닫기" Classes="caption" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <controls:ServiceDetails Grid.Row="1" />
        </Grid>
      </Border>
    </Border>
  </Grid>
</UserControl>
