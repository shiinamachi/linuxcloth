<UserControl
    x:Class="LinuxCloth.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LinuxCloth.Desktop.Controls"
    Background="{DynamicResource AppBackgroundBrush}"
    KeyDown="OnKeyDown">
  <UserControl.Styles>
    <Style Selector="ListBox.category-list">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.category-list > ListBoxItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Margin" Value="0,2" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>
    <Style Selector="ListBox.category-list > ListBoxItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
    </Style>
    <Style Selector="ListBox.category-list > ListBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="ListBox.category-list > ListBoxItem:selected TextBlock">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="ListBox.service-grid">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.service-grid > ListBoxItem">
      <Setter Property="Width" Value="220" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,12,12" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="CornerRadius" Value="14" />
    </Style>
    <Style Selector="ListBox.service-grid > ListBoxItem:pointerover Border.service-card">
      <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
      <Setter Property="Background" Value="{DynamicResource SurfaceOverlayBrush}" />
    </Style>
    <Style Selector="ListBox.service-grid > ListBoxItem:selected Border.service-card">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="1.5" />
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto">
    <!-- Desktop header -->
    <Border
        x:Name="DesktopHeader"
        Grid.Row="0"
        Padding="20,14"
        Background="{DynamicResource SurfaceBrush}"
        BorderBrush="{DynamicResource BorderSubtleBrush}"
        BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10" VerticalAlignment="Center">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Border Width="36" Height="36" CornerRadius="10" Background="{DynamicResource AccentBrush}">
            <TextBlock
                Text="lc"
                Foreground="{DynamicResource TextOnAccentBrush}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="13"
                FontWeight="Bold" />
          </Border>
          <TextBlock Text="linuxcloth" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" />
        </StackPanel>

        <Border
            Grid.Column="1"
            Margin="20,0"
            MaxWidth="560"
            HorizontalAlignment="Stretch"
            Classes="search-field">
          <Grid ColumnDefinitions="Auto,*" Margin="12,0">
            <PathIcon
                Grid.Column="0"
                Width="16"
                Height="16"
                Margin="0,0,8,0"
                Foreground="{DynamicResource TextSecondaryBrush}"
                Data="{StaticResource IconSearch}"
                VerticalAlignment="Center" />
            <TextBox
                x:Name="DesktopSearchBox"
                Grid.Column="1"
                Classes="search"
                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="서비스 검색"
                AutomationProperties.AutomationId="Catalog.Search"
                AutomationProperties.Name="서비스 검색"
                AutomationProperties.HelpText="서비스 이름으로 카탈로그를 검색합니다." />
          </Grid>
        </Border>

        <Button
            x:Name="ReadinessButton"
            Grid.Column="2"
            Classes="ghost"
            Padding="12,8"
            AutomationProperties.AutomationId="Catalog.Readiness"
            AutomationProperties.Name="실행 준비 상태">
          <Button.Flyout>
            <Flyout Placement="BottomEdgeAlignedRight">
              <Border Classes="card" Width="340" Padding="16">
                <StackPanel Spacing="12">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" IsVisible="{Binding IsReady}" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource WarningBrush}" IsVisible="{Binding !IsReady}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding DoctorSummary}" FontSize="15" FontWeight="SemiBold" />
                  </StackPanel>
                  <Button
                      Classes="secondary"
                      Content="다시 확인"
                      Command="{Binding RefreshDoctorCommand}"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"
                      AutomationProperties.AutomationId="Catalog.Readiness.Refresh" />
                  <Expander
                      Classes="technical"
                      Header="기술 세부정보"
                      AutomationProperties.AutomationId="Catalog.Readiness.TechnicalDetails">
                    <ItemsControl ItemsSource="{Binding DoctorChecks}" Margin="0,8,0,0">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="24,100,*" Margin="0,4">
                            <TextBlock Text="{Binding Status}" FontWeight="Bold" />
                            <TextBlock Grid.Column="1" Text="{Binding Label}" FontWeight="SemiBold" FontSize="12" />
                            <TextBlock Grid.Column="2" Text="{Binding Detail}" Classes="muted" TextWrapping="Wrap" FontSize="11" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Expander>
                </StackPanel>
              </Border>
            </Flyout>
          </Button.Flyout>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" IsVisible="{Binding IsReady}" />
            <Ellipse Width="8" Height="8" Fill="{DynamicResource WarningBrush}" IsVisible="{Binding !IsReady}" />
            <TextBlock Text="{Binding DoctorSummary}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button
            Grid.Column="3"
            Classes="secondary"
            Padding="12,8"
            Click="OnOpenImageSetup"
            IsEnabled="{Binding CanConfigureImages}"
            AutomationProperties.AutomationId="Catalog.WindowsEnvironment"
            AutomationProperties.Name="Windows 환경 관리">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <PathIcon Width="16" Height="16" Data="{StaticResource IconDesktop}" />
            <TextBlock Text="환경" VerticalAlignment="Center" FontSize="13" />
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Compact header -->
    <Border
        x:Name="CompactHeader"
        Grid.Row="0"
        IsVisible="False"
        Padding="14,12"
        Background="{DynamicResource SurfaceBrush}"
        BorderBrush="{DynamicResource BorderSubtleBrush}"
        BorderThickness="0,0,0,1">
      <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Border Width="32" Height="32" CornerRadius="9" Background="{DynamicResource AccentBrush}">
              <TextBlock
                  Text="lc"
                  Foreground="{DynamicResource TextOnAccentBrush}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  FontSize="12"
                  FontWeight="Bold" />
            </Border>
            <TextBlock Text="linuxcloth" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
          </StackPanel>
          <Border Grid.Column="1" Classes="badge-neutral" VerticalAlignment="Center" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessBrush}" IsVisible="{Binding IsReady}" />
              <Ellipse Width="6" Height="6" Fill="{DynamicResource WarningBrush}" IsVisible="{Binding !IsReady}" />
              <TextBlock Text="{Binding DoctorSummary}" FontSize="11" FontWeight="SemiBold" />
            </StackPanel>
          </Border>
          <Button
              Grid.Column="2"
              Classes="ghost icon"
              Click="OnOpenImageSetup"
              IsEnabled="{Binding CanConfigureImages}"
              AutomationProperties.AutomationId="Catalog.WindowsEnvironment.Compact"
              AutomationProperties.Name="Windows 환경 관리">
            <PathIcon Width="17" Height="17" Data="{StaticResource IconDesktop}" />
          </Button>
        </Grid>
        <Grid Grid.Row="1" ColumnDefinitions="*,140" ColumnSpacing="8">
          <Border Classes="search-field">
            <Grid ColumnDefinitions="Auto,*" Margin="10,0">
              <PathIcon
                  Width="15"
                  Height="15"
                  Margin="0,0,8,0"
                  Foreground="{DynamicResource TextSecondaryBrush}"
                  Data="{StaticResource IconSearch}"
                  VerticalAlignment="Center" />
              <TextBox
                  x:Name="CompactSearchBox"
                  Grid.Column="1"
                  Classes="search"
                  Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                  PlaceholderText="검색"
                  AutomationProperties.AutomationId="Catalog.Search.Compact"
                  AutomationProperties.Name="서비스 검색" />
            </Grid>
          </Border>
          <ComboBox
              Grid.Column="1"
              ItemsSource="{Binding Categories}"
              SelectedItem="{Binding SelectedCategory}"
              HorizontalContentAlignment="Stretch"
              AutomationProperties.AutomationId="Catalog.Category.Compact"
              AutomationProperties.Name="서비스 분류">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </Grid>
      </Grid>
    </Border>

    <!-- Body -->
    <Grid x:Name="ContentGrid" Grid.Row="1" ColumnDefinitions="200,*,340">
      <Border
          x:Name="CategoryRail"
          Grid.Column="0"
          Padding="12,20"
          Background="{DynamicResource SurfaceBrush}"
          BorderBrush="{DynamicResource BorderSubtleBrush}"
          BorderThickness="0,0,1,0">
        <Grid RowDefinitions="*,Auto">
          <ListBox
              Grid.Row="0"
              Classes="category-list"
              ItemsSource="{Binding Categories}"
              SelectedItem="{Binding SelectedCategory}"
              AutomationProperties.AutomationId="Catalog.Categories"
              AutomationProperties.Name="서비스 분류">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Label}" FontSize="13" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <StackPanel Grid.Row="1" Spacing="8" Margin="4,16,4,0">
            <TextBlock Text="Windows 환경" Classes="eyebrow" Margin="4,0,0,0" />
            <ComboBox
                ItemsSource="{Binding Images}"
                SelectedItem="{Binding SelectedImage}"
                HorizontalAlignment="Stretch"
                AutomationProperties.AutomationId="Catalog.WindowsEnvironment.Select"
                AutomationProperties.Name="Windows 환경 선택">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button
                Classes="ghost"
                Content="환경 관리"
                Click="OnOpenImageSetup"
                IsEnabled="{Binding CanConfigureImages}"
                AutomationProperties.AutomationId="Catalog.WindowsEnvironment.Manage"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" />
          </StackPanel>
        </Grid>
      </Border>

      <Grid x:Name="ServicesContent" Grid.Column="1" RowDefinitions="Auto,Auto,*" Margin="24,20">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
          <TextBlock
              Grid.Column="0"
              Text="{Binding SelectedCategory.Label}"
              Classes="page-title"
              FontSize="22"
              VerticalAlignment="Bottom" />
          <TextBlock
              Grid.Column="1"
              Text="{Binding FilteredServices.Count, StringFormat={}{0}}"
              Classes="muted"
              FontSize="13"
              VerticalAlignment="Bottom"
              Margin="0,0,4,4" />
        </Grid>

        <Grid
            x:Name="AdaptiveFilterBar"
            Grid.Row="1"
            IsVisible="False"
            ColumnDefinitions="Auto,*"
            Margin="0,0,0,12">
          <TextBlock Text="분류" Classes="eyebrow" VerticalAlignment="Center" Margin="0,0,10,0" />
          <ComboBox
              Grid.Column="1"
              MaxWidth="240"
              HorizontalAlignment="Left"
              ItemsSource="{Binding Categories}"
              SelectedItem="{Binding SelectedCategory}"
              AutomationProperties.AutomationId="Catalog.Category.Medium"
              AutomationProperties.Name="서비스 분류">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </Grid>

        <ListBox
            x:Name="ServicesList"
            Grid.Row="2"
            Classes="service-grid"
            ItemsSource="{Binding FilteredServices}"
            SelectedItem="{Binding SelectedService}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            AutomationProperties.AutomationId="Catalog.Services"
            AutomationProperties.Name="서비스 목록">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Classes="card service-card" Padding="14" MinHeight="120">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
                  <Grid Grid.Row="0" ColumnDefinitions="44,*" ColumnSpacing="10">
                    <Border
                        Width="44"
                        Height="44"
                        CornerRadius="12"
                        Background="{DynamicResource CatalogLogoBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        Padding="5">
                      <Image Source="{Binding Image}" Stretch="Uniform" />
                    </Border>
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding DisplayName}"
                        FontWeight="SemiBold"
                        FontSize="13"
                        TextWrapping="Wrap"
                        MaxLines="2"
                        TextTrimming="CharacterEllipsis"
                        VerticalAlignment="Center" />
                  </Grid>
                  <TextBlock
                      Grid.Row="1"
                      Text="{Binding Category}"
                      Classes="muted"
                      FontSize="11"
                      VerticalAlignment="Bottom" />
                  <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Border Classes="badge-success" IsVisible="{Binding IsVerified}" Padding="8,3">
                      <TextBlock Text="{Binding CompatibilityLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" />
                    </Border>
                    <Border Classes="badge-warning" IsVisible="{Binding IsPartial}" Padding="8,3">
                      <TextBlock Text="{Binding CompatibilityLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}" />
                    </Border>
                    <Border Classes="badge-danger" IsVisible="{Binding IsBlocked}" Padding="8,3">
                      <TextBlock Text="{Binding CompatibilityLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource DangerBrush}" />
                    </Border>
                    <Border Classes="badge-neutral" IsVisible="{Binding IsUnknown}" Padding="8,3">
                      <TextBlock Text="{Binding CompatibilityLabel}" FontSize="10" FontWeight="SemiBold" Classes="muted" />
                    </Border>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <Border
          x:Name="WideDetailsPanel"
          Grid.Column="2"
          Margin="0,16,16,16"
          Classes="card"
          Padding="18">
        <Grid>
          <StackPanel
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Spacing="10"
              Margin="16"
              IsVisible="{Binding !HasSelectedService}">
            <Border Width="48" Height="48" CornerRadius="24" Background="{DynamicResource SurfaceSubtleBrush}">
              <PathIcon
                  Width="18"
                  Height="18"
                  Data="{StaticResource IconDesktop}"
                  Foreground="{DynamicResource TextSecondaryBrush}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center" />
            </Border>
            <TextBlock
                Text="서비스를 선택하세요"
                Classes="muted"
                FontSize="13"
                HorizontalAlignment="Center" />
          </StackPanel>
          <controls:ServiceDetails IsVisible="{Binding HasSelectedService}" />
        </Grid>
      </Border>
    </Grid>

    <!-- Status bar -->
    <Border
        Grid.Row="2"
        Background="{DynamicResource SurfaceBrush}"
        BorderBrush="{DynamicResource BorderSubtleBrush}"
        BorderThickness="0,1,0,0"
        Padding="16,10">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12" VerticalAlignment="Center">
        <ProgressBar
            Grid.Column="0"
            Width="64"
            Height="4"
            IsIndeterminate="True"
            IsVisible="{Binding IsBusy}"
            AutomationProperties.Name="작업 진행 중" />
        <TextBlock
            Grid.Column="1"
            Text="{Binding SessionStatus}"
            VerticalAlignment="Center"
            FontSize="12"
            Classes="muted"
            TextTrimming="CharacterEllipsis"
            AutomationProperties.LiveSetting="Polite" />
        <TextBlock
            Grid.Column="2"
            Text="{Binding ErrorMessage}"
            Classes="danger"
            FontSize="12"
            IsVisible="{Binding HasError}"
            TextTrimming="CharacterEllipsis"
            MaxWidth="360"
            AutomationProperties.LiveSetting="Assertive" />
        <Button
            Grid.Column="3"
            Classes="danger"
            Content="닫고 삭제"
            Command="{Binding StopCommand}"
            IsVisible="{Binding IsSessionRunning}"
            AutomationProperties.AutomationId="Catalog.Session.Stop"
            AutomationProperties.Name="Windows 환경 닫기 및 삭제" />
      </Grid>
    </Border>

    <!-- Details overlay / drawer -->
    <Border
        x:Name="DetailsOverlay"
        Grid.RowSpan="3"
        IsVisible="False"
        Background="{DynamicResource ScrimBrush}"
        ZIndex="20">
      <Border
          x:Name="DetailsDrawer"
          Classes="card"
          Width="400"
          MaxWidth="400"
          Margin="16"
          Padding="16"
          HorizontalAlignment="Right"
          VerticalAlignment="Stretch">
        <Grid RowDefinitions="Auto,*">
          <Button
              Grid.Row="0"
              Classes="ghost icon-sm"
              HorizontalAlignment="Right"
              Click="OnCloseDetails"
              AutomationProperties.AutomationId="Catalog.Details.Close"
              AutomationProperties.Name="서비스 상세정보 닫기">
            <PathIcon Width="14" Height="14" Data="{StaticResource IconClose}" />
          </Button>
          <controls:ServiceDetails Grid.Row="1" />
        </Grid>
      </Border>
    </Border>
  </Grid>
</UserControl>
