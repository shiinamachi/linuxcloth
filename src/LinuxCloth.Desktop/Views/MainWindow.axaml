<Window
    x:Class="LinuxCloth.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="linuxcloth"
    Width="1380"
    Height="860"
    MinWidth="1080"
    MinHeight="700"
    WindowStartupLocation="CenterScreen">
  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0" Padding="26,20" Background="#10172A" BorderBrush="#29324F" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14">
          <Border Width="42" Height="42" CornerRadius="12" Background="#6D5DFB">
            <TextBlock Text="LC" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" />
          </Border>
          <StackPanel VerticalAlignment="Center" Spacing="1">
            <TextBlock Text="linuxcloth" FontSize="22" FontWeight="Bold" />
            <TextBlock Classes="muted" Text="격리된 Windows에서 금융·공공 서비스를 엽니다" FontSize="12" />
          </StackPanel>
        </StackPanel>

        <Border Grid.Column="1" Margin="42,0" MaxWidth="620" CornerRadius="12" Background="#0B1020" BorderBrush="#313B5B" BorderThickness="1">
          <Grid ColumnDefinitions="Auto,*" Margin="14,0">
            <TextBlock Grid.Column="0" Text="⌕" FontSize="24" Foreground="#8792B2" VerticalAlignment="Center" Margin="0,0,10,2" />
            <TextBox
                Grid.Column="1"
                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="은행, 카드, 정부기관 검색"
                Background="Transparent"
                BorderThickness="0"
                Padding="0,12" />
          </Grid>
        </Border>

        <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="2">
          <TextBlock Text="{Binding DoctorSummary}" HorizontalAlignment="Right" FontWeight="SemiBold" />
          <Button Classes="secondary" Content="시스템 다시 검사" Command="{Binding RefreshDoctorCommand}" HorizontalAlignment="Right" Padding="10,4" FontSize="11" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="190,*,370">
      <Border Grid.Column="0" Padding="18,24" Background="#0E1527" BorderBrush="#29324F" BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*,Auto">
          <TextBlock Grid.Row="0" Text="서비스 분류" Classes="muted" FontSize="12" FontWeight="SemiBold" Margin="10,0,0,12" />
          <ListBox
              Grid.Row="1"
              ItemsSource="{Binding Categories}"
              SelectedItem="{Binding SelectedCategory}"
              Background="Transparent"
              BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Margin="8,5" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <Border Grid.Row="2" Classes="card" Padding="12" Margin="0,18,0,0">
            <StackPanel Spacing="7">
              <TextBlock Text="Windows 이미지" FontSize="11" Classes="muted" />
              <ComboBox ItemsSource="{Binding Images}" SelectedItem="{Binding SelectedImage}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock
                  IsVisible="{Binding !HasImages}"
                  Text="등록된 이미지가 없습니다.&#10;CLI의 image build 안내를 따라 먼저 준비하세요."
                  TextWrapping="Wrap"
                  Classes="muted"
                  FontSize="11" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="24">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="2,0,2,16">
          <StackPanel Grid.Column="0" Spacing="3">
            <TextBlock Text="공식 TableCloth 카탈로그" FontSize="20" FontWeight="Bold" />
            <TextBlock Classes="muted" Text="Linux 검증 정보는 공식 데이터와 분리해 표시합니다." FontSize="12" />
          </StackPanel>
          <TextBlock Grid.Column="1" Text="{Binding FilteredServices.Count, StringFormat={}{0}개 서비스}" Classes="muted" VerticalAlignment="Bottom" />
        </Grid>

        <ListBox
            Grid.Row="1"
            ItemsSource="{Binding FilteredServices}"
            SelectedItem="{Binding SelectedService}"
            Background="Transparent"
            BorderThickness="0"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Classes="card" Width="216" Height="150" Margin="5" Padding="16">
                <Grid RowDefinitions="Auto,*,Auto">
                  <Grid Grid.Row="0" ColumnDefinitions="52,*">
                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10" Background="White" Padding="5">
                      <Image Source="{Binding Image}" Stretch="Uniform" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,2,0,0" Spacing="2">
                      <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding Category}" Classes="muted" FontSize="11" />
                    </StackPanel>
                  </Grid>
                  <TextBlock Grid.Row="1" Text="{Binding Url}" Classes="muted" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                  <Border Grid.Row="2" HorizontalAlignment="Left" CornerRadius="8" Background="#222C49" Padding="8,4">
                    <TextBlock Text="{Binding CompatibilityLabel}" FontSize="10" FontWeight="SemiBold" />
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <Border Grid.Column="2" Margin="0,24,24,24" Classes="card" Padding="22">
        <Grid RowDefinitions="*,Auto">
          <ScrollViewer Grid.Row="0">
            <StackPanel Spacing="15" IsVisible="{Binding HasSelectedService}">
              <Border Width="88" Height="88" CornerRadius="18" Background="White" Padding="9" HorizontalAlignment="Left">
                <Image Source="{Binding SelectedService.Image}" Stretch="Uniform" />
              </Border>
              <StackPanel Spacing="3">
                <TextBlock Text="{Binding SelectedService.DisplayName}" FontSize="25" FontWeight="Bold" TextWrapping="Wrap" />
                <TextBlock Text="{Binding SelectedService.EnglishDisplayName}" Classes="muted" />
              </StackPanel>
              <Border CornerRadius="9" Background="#222C49" Padding="10,6" HorizontalAlignment="Left">
                <TextBlock Text="{Binding SelectedService.CompatibilityLabel}" FontWeight="SemiBold" FontSize="11" />
              </Border>
              <StackPanel Spacing="5">
                <TextBlock Text="공식 주소" Classes="muted" FontSize="11" />
                <TextBlock Text="{Binding SelectedService.Url}" TextWrapping="Wrap" />
              </StackPanel>
              <StackPanel Spacing="5">
                <TextBlock Text="Windows 준비 항목" Classes="muted" FontSize="11" />
                <TextBlock Text="{Binding SelectedService.PackageSummary}" TextWrapping="Wrap" />
              </StackPanel>
              <StackPanel Spacing="5">
                <TextBlock Text="호환성 안내" Classes="muted" FontSize="11" />
                <TextBlock Text="{Binding SelectedService.CompatibilityNotes}" TextWrapping="Wrap" />
              </StackPanel>
              <Border IsVisible="{Binding SelectedService.HasCustomBootstrap}" Background="#3D2B22" CornerRadius="9" Padding="12">
                <TextBlock Text="이 서비스는 공식 사용자 정의 부트스트랩을 실행합니다." TextWrapping="Wrap" FontSize="11" />
              </Border>
            </StackPanel>
          </ScrollViewer>

          <StackPanel Grid.Row="1" Spacing="10" Margin="0,20,0,0">
            <Button
                Classes="primary"
                Content="일회용 Windows에서 열기"
                Command="{Binding LaunchCommand}"
                IsEnabled="{Binding CanLaunch}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" />
            <Button
                Classes="secondary"
                Content="세션 종료 및 삭제"
                Command="{Binding StopCommand}"
                IsVisible="{Binding IsSessionRunning}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2" Background="#10172A" BorderBrush="#29324F" BorderThickness="0,1,0,0" Padding="24,12">
      <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
        <ProgressBar Grid.Column="0" Width="90" IsIndeterminate="True" IsVisible="{Binding IsBusy}" Margin="0,0,14,0" />
        <TextBlock Grid.Column="1" Text="{Binding SessionStatus}" VerticalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="{Binding ErrorMessage}" Foreground="#FF9E9E" IsVisible="{Binding HasError}" TextTrimming="CharacterEllipsis" MaxWidth="520" />
      </Grid>
    </Border>
  </Grid>
</Window>
