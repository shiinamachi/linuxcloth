<Window
    x:Class="LinuxCloth.Desktop.Views.ActiveOperationCloseDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:localization="using:LinuxCloth.Desktop.Localization"
    Title="{Binding [CloseDialog.WindowTitle], Source={x:Static localization:UiStrings.Instance}}"
    Width="480"
    Height="220"
    CanResize="False"
    WindowStartupLocation="CenterOwner"
    Background="{DynamicResource SurfaceRaisedBrush}">
  <Grid RowDefinitions="*,Auto" Margin="24">
    <StackPanel Spacing="12">
      <TextBlock
          Text="{Binding [CloseDialog.Title], Source={x:Static localization:UiStrings.Instance}}"
          Classes="dialog-title"
          TextWrapping="Wrap" />
      <TextBlock
          Text="{Binding [CloseDialog.Description], Source={x:Static localization:UiStrings.Instance}}"
          Classes="body muted"
          TextWrapping="Wrap" />
    </StackPanel>
    <StackPanel
        Grid.Row="1"
        Orientation="Horizontal"
        HorizontalAlignment="Right"
        Spacing="8"
        Margin="0,20,0,0">
      <Button
          Classes="secondary"
          Content="{Binding [CloseDialog.KeepWorking], Source={x:Static localization:UiStrings.Instance}}"
          Click="OnKeepWorking"
          IsDefault="True"
          IsCancel="True"
          AutomationProperties.AutomationId="ActiveOperation.KeepWorking" />
      <Button
          Classes="primary"
          Content="{Binding [CloseDialog.Stop], Source={x:Static localization:UiStrings.Instance}}"
          Click="OnStopAndClose"
          AutomationProperties.AutomationId="ActiveOperation.StopAndClose" />
    </StackPanel>
  </Grid>
</Window>
