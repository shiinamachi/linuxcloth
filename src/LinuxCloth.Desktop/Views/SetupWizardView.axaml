<UserControl
    x:Class="LinuxCloth.Desktop.Views.SetupWizardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource AppBackgroundBrush}">
  <Grid RowDefinitions="Auto,Auto,*,Auto">
    <Border Grid.Row="0" Classes="chrome-bar">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
        <StackPanel Spacing="2">
          <TextBlock Text="Windows 환경 준비" Classes="section-title" />
          <TextBlock Text="서비스를 열 때 사용할 환경을 준비합니다." Classes="caption" />
        </StackPanel>
        <TextBlock
            Grid.Column="1"
            Text="{Binding StepProgressText}"
            VerticalAlignment="Center"
            Classes="caption" />
      </Grid>
    </Border>

    <Border
        x:Name="CompactStepHeader"
        Grid.Row="1"
        IsVisible="False"
        Classes="chrome-bar"
        Background="{DynamicResource SurfaceSubtleBrush}">
      <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
        <TextBlock Text="{Binding StepProgressText}" Classes="caption" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="{Binding CurrentTitle}" FontWeight="Bold" Classes="body" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Grid x:Name="WizardBody" Grid.Row="2" ColumnDefinitions="200,*">
      <Border
          x:Name="StepRail"
          Grid.Column="0"
          Padding="8,12"
          Background="{DynamicResource AppBackgroundBrush}"
          BorderBrush="{DynamicResource BorderSubtleBrush}"
          BorderThickness="0,0,1,0">
        <Grid RowDefinitions="*,Auto">
          <ItemsControl Grid.Row="0" ItemsSource="{Binding Steps}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="6,6" Margin="0,0,0,2">
                  <Grid ColumnDefinitions="20,*" ColumnSpacing="8">
                    <Ellipse
                        Width="12"
                        Height="12"
                        Stroke="{DynamicResource TextSecondaryBrush}"
                        StrokeThickness="1"
                        Fill="Transparent"
                        VerticalAlignment="Center"
                        IsVisible="{Binding !IsCurrent}" />
                    <Ellipse
                        Width="12"
                        Height="12"
                        Stroke="{DynamicResource AccentBrush}"
                        StrokeThickness="1"
                        Fill="{DynamicResource AccentBrush}"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsCurrent}" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding Title}"
                        VerticalAlignment="Center"
                        TextWrapping="Wrap"
                        FontWeight="Normal"
                        IsVisible="{Binding !IsCurrent}"
                        Classes="caption" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding Title}"
                        VerticalAlignment="Center"
                        TextWrapping="Wrap"
                        FontWeight="Bold"
                        Classes="body"
                        IsVisible="{Binding IsCurrent}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Border Grid.Row="1" Classes="notice-warning" Margin="4,8,4,0">
            <TextBlock
                Text="테스트 전용입니다. 실제 업무에는 사용하지 마세요."
                TextWrapping="Wrap"
                Classes="meta warning"
                FontWeight="Bold" />
          </Border>
        </Grid>
      </Border>

      <Grid x:Name="WizardContent" Grid.Column="1" RowDefinitions="Auto,*" Margin="16,12">
        <TextBlock
            Grid.Row="0"
            Text="{Binding CurrentTitle}"
            Classes="dialog-title"
            Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <Grid MaxWidth="860" HorizontalAlignment="Stretch" Margin="0,0,4,8">
            <StackPanel IsVisible="{Binding IsHostInspectionStep}" Spacing="10">
              <Border Classes="card">
                <StackPanel Spacing="10">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="확인 결과" Classes="section-title" VerticalAlignment="Center" />
                    <Button
                        Grid.Column="1"
                        Classes="secondary"
                        Content="다시 확인"
                        Command="{Binding ReinspectCommand}"
                        AutomationProperties.AutomationId="Setup.Host.Refresh"
                        AutomationProperties.Name="시스템 다시 확인" />
                  </Grid>
                  <ItemsControl ItemsSource="{Binding HostChecks}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1" Padding="2,8">
                          <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="20,*,Auto" ColumnSpacing="8">
                            <PathIcon
                                Width="14"
                                Height="14"
                                Data="{StaticResource IconCheck}"
                                Foreground="{DynamicResource SuccessBrush}"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsAvailable}" />
                            <PathIcon
                                Width="14"
                                Height="14"
                                Data="{StaticResource IconAlert}"
                                Foreground="{DynamicResource DangerBrush}"
                                VerticalAlignment="Center"
                                IsVisible="{Binding !IsAvailable}" />
                            <TextBlock Grid.Column="1" Text="{Binding Label}" Classes="body" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding StatusLabel}" Classes="meta" VerticalAlignment="Center" />
                            <Expander
                                Grid.Row="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Classes="technical"
                                Header="세부정보"
                                AutomationProperties.AutomationId="Setup.Host.CheckDetails">
                              <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Classes="meta" Margin="0,4,0,0" />
                            </Expander>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
              <Border Classes="notice-info">
                <TextBlock
                    Text="가상화가 꺼져 있으면 펌웨어에서 켠 뒤 다시 확인하세요. 관리자 권한은 필요 없습니다."
                    TextWrapping="Wrap"
                    />
              </Border>
            </StackPanel>

            <StackPanel IsVisible="{Binding IsComponentsStep}" Spacing="10">
              <Border Classes="card">
                <StackPanel Spacing="10">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                      <TextBlock Text="필수 구성 요소" Classes="section-title" />
                      <TextBlock Text="{Binding DistributionLabel}" Classes="caption" />
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        Classes="secondary"
                        Content="다시 확인"
                        Command="{Binding ReinspectCommand}"
                        AutomationProperties.AutomationId="Setup.Components.Refresh" />
                  </Grid>
                  <TextBlock Text="{Binding PackageStatus}" TextWrapping="Wrap" />
                  <Button
                      Classes="primary"
                      Content="필수 구성 요소 설치"
                      Command="{Binding InstallPackagesCommand}"
                      IsEnabled="{Binding CanInstallPackages}"
                      HorizontalAlignment="Left"
                      AutomationProperties.AutomationId="Setup.Components.Install"
                      AutomationProperties.HelpText="필요한 경우 시스템 인증 후 설치합니다." />
                  <TextBlock
                      IsVisible="{Binding HasUnresolvedPackages}"
                      Text="{Binding UnresolvedPackages, StringFormat=준비하지 못한 항목: {0}}"
                      Classes="danger"
                      TextWrapping="Wrap" />
                  <Expander
                      Classes="technical"
                      Header="설치 세부정보"
                      AutomationProperties.AutomationId="Setup.Components.InstallDetails">
                    <StackPanel Spacing="8" Margin="0,6,0,0">
                      <ItemsControl ItemsSource="{Binding PackageChanges}" MaxHeight="220">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="160,110,*,Auto" ColumnSpacing="8" Margin="0,3">
                              <TextBlock Text="{Binding Name}" />
                              <TextBlock Grid.Column="1" Text="{Binding Version}" Classes="caption" TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="2" Text="{Binding Repository}" Classes="caption" TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="3" Text="{Binding Kind}" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <TextBlock Text="{Binding PackageRepositories, StringFormat=저장소: {0}}" Classes="caption" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding PackageDownloadSize, StringFormat=다운로드: {0}}" Classes="meta" />
                    </StackPanel>
                  </Expander>
                </StackPanel>
              </Border>

              <Border IsVisible="{Binding ShowManualCommand}" Classes="card">
                <StackPanel Spacing="8">
                  <TextBlock Text="직접 설치가 필요합니다" Classes="section-title" />
                  <TextBlock Text="아래 명령을 터미널에서 실행한 뒤 다시 확인하세요." Classes="caption" TextWrapping="Wrap" />
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBox
                        Text="{Binding ManualInstallCommand}"
                        IsReadOnly="True"
                        AutomationProperties.AutomationId="Setup.Components.ManualCommand"
                        AutomationProperties.Name="수동 설치 명령" />
                    <Button
                        Grid.Column="1"
                        Classes="secondary"
                        Content="복사"
                        Click="OnCopyManualCommand"
                        AutomationProperties.AutomationId="Setup.Components.CopyManualCommand" />
                  </Grid>
                </StackPanel>
              </Border>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Border Classes="subtle-card">
                  <StackPanel Spacing="2">
                    <TextBlock Text="Windows 연결" Classes="meta" />
                    <TextBlock Text="{Binding GuestBridgeStatus}" FontWeight="Bold" Classes="body" />
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="subtle-card">
                  <StackPanel Spacing="2">
                    <TextBlock Text="Windows 시작" Classes="meta" />
                    <TextBlock Text="{Binding FirmwareStatus}" FontWeight="Bold" Classes="body" />
                  </StackPanel>
                </Border>
              </Grid>
              <Expander
                  Classes="technical"
                  Header="기술 세부정보"
                  AutomationProperties.AutomationId="Setup.Components.TechnicalDetails">
                <StackPanel Spacing="4" Margin="0,6,0,0">
                  <TextBlock Text="{Binding GuestBridgeStatus, StringFormat=GuestBridge: {0}}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding FirmwareStatus, StringFormat=Secure Boot OVMF: {0}}" TextWrapping="Wrap" />
                </StackPanel>
              </Expander>
            </StackPanel>

            <StackPanel IsVisible="{Binding IsWindowsMediaStep}" Spacing="10">
              <Border Classes="card">
                <StackPanel Spacing="10">
                  <TextBlock
                      Text="Microsoft 64비트 ISO를 선택하세요. 파일은 이 컴퓨터에서만 검사합니다."
                      Classes="caption"
                      TextWrapping="Wrap"
                      />
                  <WrapPanel Orientation="Horizontal">
                    <Button
                        Classes="secondary"
                        Content="다운로드 페이지"
                        Click="OnOpenWindowsDownload"
                        IsEnabled="{Binding !IsBusy}"
                        Margin="0,0,8,0"
                        AutomationProperties.AutomationId="Setup.WindowsMedia.Download" />
                    <Button
                        Classes="primary"
                        Content="ISO 파일 선택"
                        Click="OnBrowseWindowsIso"
                        IsEnabled="{Binding !IsBusy}"
                        AutomationProperties.AutomationId="Setup.WindowsMedia.Select"
                        AutomationProperties.Name="Windows 11 ISO 선택" />
                  </WrapPanel>
                  <Border Classes="subtle-card">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{Binding WindowsMediaName}" FontWeight="Bold" />
                      <TextBlock Text="{Binding WindowsMediaStatus}" TextWrapping="Wrap" Classes="caption" />
                    </StackPanel>
                  </Border>
                  <CheckBox
                      IsChecked="{Binding IsLicenseConfirmed}"
                      Content="사용할 수 있는 Windows 라이선스가 있습니다"
                      AutomationProperties.AutomationId="Setup.WindowsMedia.License"
                      AutomationProperties.HelpText="Windows 사용 권한 확인" />
                  <CheckBox
                      IsChecked="{Binding RememberMediaPaths}"
                      Content="파일 위치 기억"
                      AutomationProperties.AutomationId="Setup.WindowsMedia.RememberPath" />
                  <Expander
                      Classes="technical"
                      Header="기술 세부정보"
                      AutomationProperties.AutomationId="Setup.WindowsMedia.TechnicalDetails">
                    <StackPanel Spacing="4" Margin="0,6,0,0">
                      <TextBlock Text="{Binding WindowsMediaPath}" TextWrapping="Wrap" Classes="mono" />
                      <TextBlock Text="{Binding WindowsMediaHash, StringFormat=SHA-256  {0}}" Classes="caption mono" TextWrapping="Wrap" />
                    </StackPanel>
                  </Expander>
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel IsVisible="{Binding IsVirtioMediaStep}" Spacing="10">
              <Border Classes="card">
                <StackPanel Spacing="10">
                  <TextBlock
                      Text="디스크와 네트워크용 공식 드라이버 ISO가 필요합니다."
                      Classes="caption"
                      TextWrapping="Wrap"
                      />
                  <Border Classes="notice-warning">
                    <TextBlock
                        Text="자동 다운로드는 제공하지 않습니다. 공식 배포 페이지에서 stable ISO를 받아 선택하세요."
                        TextWrapping="Wrap"
                        />
                  </Border>
                  <WrapPanel Orientation="Horizontal">
                    <Button
                        Classes="secondary"
                        Content="다운로드 페이지"
                        Click="OnOpenVirtioDownload"
                        IsEnabled="{Binding !IsBusy}"
                        Margin="0,0,8,0"
                        AutomationProperties.AutomationId="Setup.Drivers.Download" />
                    <Button
                        Classes="primary"
                        Content="드라이버 ISO 선택"
                        Click="OnBrowseVirtioIso"
                        IsEnabled="{Binding !IsBusy}"
                        AutomationProperties.AutomationId="Setup.Drivers.Select"
                        AutomationProperties.Name="Windows 드라이버 ISO 선택" />
                  </WrapPanel>
                  <Border Classes="subtle-card">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{Binding VirtioMediaName}" FontWeight="Bold" />
                      <TextBlock Text="{Binding VirtioMediaStatus}" TextWrapping="Wrap" Classes="caption" />
                    </StackPanel>
                  </Border>
                  <Expander
                      Classes="technical"
                      Header="기술 세부정보"
                      AutomationProperties.AutomationId="Setup.Drivers.TechnicalDetails">
                    <StackPanel Spacing="4" Margin="0,6,0,0">
                      <TextBlock Text="virtio-win · Windows 11 amd64 vioscsi · NetKVM" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding VirtioMediaPath}" TextWrapping="Wrap" Classes="mono" />
                      <TextBlock Text="{Binding VirtioMediaHash, StringFormat=SHA-256  {0}}" Classes="caption mono" TextWrapping="Wrap" />
                    </StackPanel>
                  </Expander>
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel IsVisible="{Binding IsImageBuildStep}" Spacing="10">
              <Border Classes="card">
                <StackPanel Spacing="8">
                  <TextBlock Text="실행 전 확인" Classes="section-title" />
                  <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                    <TextBlock Text="설치 파일" Classes="caption" />
                    <TextBlock Grid.Column="1" Text="{Binding WindowsMediaName}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="1" Text="드라이버" Classes="caption" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding VirtioMediaName}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="2" Text="Windows 연결" Classes="caption" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GuestBridgeStatus}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="3" Text="Windows 시작" Classes="caption" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FirmwareStatus}" TextWrapping="Wrap" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="card">
                <StackPanel Spacing="10">
                  <TextBlock Text="환경 설정" Classes="section-title" />
                  <StackPanel Spacing="4">
                    <TextBlock Text="환경 이름" Classes="caption" />
                    <TextBox
                        Text="{Binding Build.ImageIdText}"
                        IsReadOnly="{Binding Build.IsBuilding}"
                        AutomationProperties.AutomationId="Setup.Build.EnvironmentName"
                        AutomationProperties.Name="Windows 환경 이름" />
                  </StackPanel>
                  <Expander
                      Classes="technical"
                      Header="고급 리소스 설정"
                      AutomationProperties.AutomationId="Setup.Build.AdvancedResources">
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="0,8,0,0">
                      <StackPanel>
                        <TextBlock Text="디스크 (GiB)" Classes="caption" />
                        <NumericUpDown
                            Value="{Binding Build.DiskSizeGiB}"
                            Minimum="64"
                            Maximum="1024"
                            Increment="8"
                            AutomationProperties.AutomationId="Setup.Build.DiskSize"
                            AutomationProperties.Name="Windows 디스크 크기" />
                      </StackPanel>
                      <StackPanel Grid.Column="1">
                        <TextBlock Text="가상 CPU" Classes="caption" />
                        <NumericUpDown
                            Value="{Binding Build.CpuCount}"
                            Minimum="2"
                            Maximum="32"
                            AutomationProperties.AutomationId="Setup.Build.CpuCount"
                            AutomationProperties.Name="가상 CPU 수" />
                      </StackPanel>
                      <StackPanel Grid.Column="2">
                        <TextBlock Text="메모리 (MiB)" Classes="caption" />
                        <NumericUpDown
                            Value="{Binding Build.MemoryMiB}"
                            Minimum="4096"
                            Maximum="131072"
                            Increment="1024"
                            AutomationProperties.AutomationId="Setup.Build.Memory"
                            AutomationProperties.Name="Windows 메모리 크기" />
                      </StackPanel>
                    </Grid>
                  </Expander>
                  <TextBlock
                      Text="{Binding Build.ResourceWarning}"
                      IsVisible="{Binding Build.HasResourceWarning}"
                      Foreground="{DynamicResource WarningBrush}"
                      TextWrapping="Wrap"
                      />
                </StackPanel>
              </Border>

              <Border Classes="notice-info">
                <TextBlock
                    Text="설치 창이 별도로 열립니다. 보유 라이선스에 맞는 에디션을 설치하면 환경 확인이 이어집니다."
                    TextWrapping="Wrap"
                    />
              </Border>

              <Border Classes="card">
                <StackPanel Spacing="8">
                  <ProgressBar
                      IsIndeterminate="True"
                      IsVisible="{Binding Build.IsBuilding}"
                      AutomationProperties.Name="Windows 환경 준비 진행 중" />
                  <TextBlock
                      Text="{Binding Build.BuildStatus}"
                      TextWrapping="Wrap"
                     
                      AutomationProperties.Name="Windows 환경 준비 상태"
                      AutomationProperties.LiveSetting="Polite" />
                  <TextBlock
                      x:Name="BuildErrorSummary"
                      Text="{Binding Build.ErrorMessage}"
                      IsVisible="{Binding Build.HasError}"
                      Classes="danger"
                      TextWrapping="Wrap"
                      Focusable="True"
                      AutomationProperties.Name="Windows 환경 준비 오류"
                      AutomationProperties.LiveSetting="Assertive" />
                  <Expander
                      Classes="technical"
                      Header="작업 세부정보"
                      IsVisible="{Binding Build.HasStagingDirectory}"
                      AutomationProperties.AutomationId="Setup.Build.OperationDetails">
                    <TextBlock
                        Text="{Binding Build.StagingDirectory}"
                        Classes="caption mono"
                        TextWrapping="Wrap"
                        Margin="0,6,0,0" />
                  </Expander>
                  <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button
                        Classes="secondary"
                        Content="이전 작업 계속"
                        Command="{Binding Build.ResumeBuildCommand}"
                        IsEnabled="{Binding Build.CanResumeBuild}"
                        IsVisible="{Binding Build.HasStagingDirectory}"
                        Margin="0,0,6,0"
                        AutomationProperties.AutomationId="Setup.Build.Resume" />
                    <Button
                        Classes="primary"
                        Content="Windows 환경 만들기"
                        Command="{Binding Build.StartBuildCommand}"
                        IsEnabled="{Binding Build.CanStartBuild}"
                        IsVisible="{Binding !Build.IsBuilding}"
                        Margin="0,0,6,0"
                        AutomationProperties.AutomationId="Setup.Build.Start" />
                    <Button
                        Classes="secondary"
                        Content="안전하게 중단"
                        Command="{Binding Build.CancelBuildCommand}"
                        IsVisible="{Binding Build.IsBuilding}"
                        AutomationProperties.AutomationId="Setup.Build.Cancel" />
                  </WrapPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </ScrollViewer>
      </Grid>
    </Grid>

    <Border Grid.Row="3" Classes="status-strip" Background="{DynamicResource SurfaceRaisedBrush}">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="6">
        <Button
            Grid.Column="0"
            Classes="secondary"
            Content="나중에"
            Command="{Binding LaterCommand}"
            AutomationProperties.AutomationId="Setup.Navigation.Later" />
        <TextBlock
            x:Name="ErrorSummary"
            Grid.Column="1"
            Text="{Binding ErrorMessage}"
            IsVisible="{Binding HasError}"
            Classes="danger caption"
            TextTrimming="CharacterEllipsis"
            VerticalAlignment="Center"
            Margin="8,0"
            Focusable="True"
            AutomationProperties.Name="현재 단계 오류"
            AutomationProperties.LiveSetting="Assertive" />
        <Button
            Grid.Column="2"
            Classes="secondary"
            Content="뒤로"
            Command="{Binding BackCommand}"
            IsEnabled="{Binding CanGoBack}"
            AutomationProperties.AutomationId="Setup.Navigation.Back" />
        <Button
            Grid.Column="3"
            Classes="primary"
            Content="{Binding ContinueLabel}"
            Command="{Binding ContinueCommand}"
            IsEnabled="{Binding CanContinue}"
            IsVisible="{Binding !IsImageBuildStep}"
            AutomationProperties.AutomationId="Setup.Navigation.Continue" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
