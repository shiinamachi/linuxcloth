<UserControl
    x:Class="LinuxCloth.Desktop.Views.SetupWizardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AutomationProperties.AutomationId="Setup.Flow">
  <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource AppBackgroundBrush}">
    <Border Grid.Row="0" Classes="chrome-bar" IsVisible="{Binding IsReady}">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
        <StackPanel Spacing="4">
          <TextBlock Text="Windows 환경 준비" Classes="page-title" />
          <TextBlock
              Text="필요한 항목을 선택하면 설치부터 확인까지 한 번에 진행합니다."
              Classes="caption"
              TextWrapping="Wrap" />
        </StackPanel>
        <Button
            Grid.Column="1"
            Classes="secondary"
            Content="나중에"
            Command="{Binding LaterCommand}"
            VerticalAlignment="Top"
            AutomationProperties.AutomationId="Setup.Later" />
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
      <Grid x:Name="ContentFrame" MaxWidth="720" Margin="24,8,24,24" HorizontalAlignment="Stretch">

        <!-- Ready: inputs -->
        <StackPanel IsVisible="{Binding IsReady}" Spacing="12">
          <Border Classes="card" Padding="16,14">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
              <PathIcon
                  Width="28"
                  Height="28"
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource SuccessBrush}"
                  Data="{StaticResource IconCheckCircle}"
                  IsVisible="{Binding IsHostReady}" />
              <PathIcon
                  Width="28"
                  Height="28"
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource WarningBrush}"
                  Data="{StaticResource IconAlert}"
                  IsVisible="{Binding !IsHostReady}" />
              <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="시스템 준비" Classes="instruction" FontWeight="SemiBold" />
                <TextBlock
                    Text="{Binding HostStatus}"
                    Classes="caption"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource SuccessBrush}"
                    IsVisible="{Binding IsHostReady}" />
                <TextBlock
                    Text="{Binding HostStatus}"
                    Classes="caption"
                    TextWrapping="Wrap"
                    IsVisible="{Binding !IsHostReady}" />
              </StackPanel>
              <Button
                  Grid.Column="2"
                  Classes="secondary"
                  VerticalAlignment="Center"
                  Command="{Binding ReinspectCommand}"
                  AutomationProperties.AutomationId="Setup.Host.Refresh"
                  AutomationProperties.Name="시스템 준비 다시 확인">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Width="14" Height="14" Data="{StaticResource IconRefresh}" />
                  <TextBlock Text="다시 확인" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </Grid>
          </Border>

          <Border Classes="card" Padding="0">
            <StackPanel>
              <Border Classes="form-row" BorderThickness="0,0,0,1">
                <TextBlock Text="설치 파일" Classes="instruction" FontWeight="SemiBold" />
              </Border>

              <Border Classes="form-row">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                  <PathIcon
                      Width="20"
                      Height="20"
                      VerticalAlignment="Center"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      Data="{StaticResource IconFile}" />
                  <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="Windows 11" Classes="body" FontWeight="SemiBold" />
                    <TextBlock
                        Text="{Binding WindowsMediaName}"
                        Classes="meta"
                        TextWrapping="Wrap"
                        IsVisible="{Binding IsWindowsMediaValid}" />
                  </StackPanel>
                  <StackPanel
                      Grid.Column="2"
                      Orientation="Horizontal"
                      Spacing="4"
                      VerticalAlignment="Center"
                      IsVisible="{Binding IsWindowsMediaValid}">
                    <PathIcon
                        Width="14"
                        Height="14"
                        Foreground="{DynamicResource SuccessBrush}"
                        Data="{StaticResource IconCheckCircle}"
                        VerticalAlignment="Center" />
                    <TextBlock
                        Text="{Binding WindowsMediaStatus}"
                        Classes="caption success"
                        VerticalAlignment="Center"
                        MaxWidth="220"
                        TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                  <TextBlock
                      Grid.Column="2"
                      Text="{Binding WindowsMediaStatus}"
                      Classes="caption"
                      VerticalAlignment="Center"
                      MaxWidth="220"
                      TextWrapping="Wrap"
                      IsVisible="{Binding !IsWindowsMediaValid}" />
                  <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button
                        Classes="ghost"
                        Content="받기"
                        Click="OnOpenWindowsDownload"
                        AutomationProperties.AutomationId="Setup.Windows.Download" />
                    <Button
                        Classes="secondary"
                        Click="OnBrowseWindowsIso"
                        AutomationProperties.AutomationId="Setup.Windows.Select"
                        AutomationProperties.Name="Windows 11 설치 파일 선택">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Width="14" Height="14" Data="{StaticResource IconFolder}" />
                        <TextBlock Text="파일 선택" VerticalAlignment="Center" />
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </Grid>
              </Border>

              <StackPanel IsVisible="{Binding HasMultipleWindowsEditions}" Margin="16,0,16,12" Spacing="4">
                <TextBlock Text="설치할 Windows 버전" Classes="caption" />
                <ComboBox
                    ItemsSource="{Binding WindowsEditions}"
                    SelectedItem="{Binding SelectedWindowsEdition}"
                    AutomationProperties.AutomationId="Setup.Windows.Edition"
                    AutomationProperties.Name="설치할 Windows 버전">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <Border Classes="form-row" BorderThickness="0">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                  <PathIcon
                      Width="20"
                      Height="20"
                      VerticalAlignment="Center"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      Data="{StaticResource IconGear}" />
                  <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="Windows 장치 드라이버" Classes="body" FontWeight="SemiBold" />
                    <TextBlock
                        Text="{Binding VirtioMediaName}"
                        Classes="meta"
                        TextWrapping="Wrap"
                        IsVisible="{Binding IsVirtioMediaValid}" />
                  </StackPanel>
                  <StackPanel
                      Grid.Column="2"
                      Orientation="Horizontal"
                      Spacing="4"
                      VerticalAlignment="Center"
                      IsVisible="{Binding IsVirtioMediaValid}">
                    <PathIcon
                        Width="14"
                        Height="14"
                        Foreground="{DynamicResource SuccessBrush}"
                        Data="{StaticResource IconCheckCircle}"
                        VerticalAlignment="Center" />
                    <TextBlock
                        Text="{Binding VirtioMediaStatus}"
                        Classes="caption success"
                        VerticalAlignment="Center"
                        MaxWidth="220"
                        TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                  <TextBlock
                      Grid.Column="2"
                      Text="{Binding VirtioMediaStatus}"
                      Classes="caption"
                      VerticalAlignment="Center"
                      MaxWidth="220"
                      TextWrapping="Wrap"
                      IsVisible="{Binding !IsVirtioMediaValid}" />
                  <Button
                      Grid.Column="3"
                      Classes="secondary"
                      Click="OnBrowseVirtioIso"
                      VerticalAlignment="Center"
                      AutomationProperties.AutomationId="Setup.Drivers.Select"
                      AutomationProperties.Name="Windows 장치 드라이버 파일 선택">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <PathIcon Width="14" Height="14" Data="{StaticResource IconFolder}" />
                      <TextBlock Text="로컬 파일 선택" VerticalAlignment="Center" />
                    </StackPanel>
                  </Button>
                </Grid>
              </Border>
            </StackPanel>
          </Border>

          <StackPanel Spacing="8" Margin="4,0">
            <CheckBox
                IsChecked="{Binding IsLicenseConfirmed}"
                Content="이 Windows 버전을 사용할 수 있는 라이선스가 있습니다"
                AutomationProperties.AutomationId="Setup.License"
                AutomationProperties.HelpText="Windows 사용 권한 확인" />
            <CheckBox
                IsChecked="{Binding RememberMediaPaths}"
                Content="다음 실행을 위해 파일 위치 기억"
                AutomationProperties.AutomationId="Setup.RememberMedia" />
          </StackPanel>

          <Border Classes="card" Padding="0">
            <Expander
                Classes="technical"
                Header="고급 설정"
                Margin="12,4"
                AutomationProperties.AutomationId="Setup.Advanced">
              <StackPanel Spacing="10" Margin="4,8,4,12">
                <StackPanel Spacing="4">
                  <TextBlock Text="환경 이름" Classes="caption" />
                  <TextBox
                      Text="{Binding ImageIdText}"
                      AutomationProperties.AutomationId="Setup.ImageId"
                      AutomationProperties.Name="Windows 환경 이름" />
                </StackPanel>
                <WrapPanel Orientation="Horizontal">
                  <StackPanel Width="190" Margin="0,0,10,8">
                    <TextBlock Text="디스크 (GiB)" Classes="caption" />
                    <NumericUpDown
                        Value="{Binding DiskSizeGiB}"
                        Minimum="64"
                        Maximum="1024"
                        Increment="8"
                        AutomationProperties.AutomationId="Setup.DiskSize" />
                  </StackPanel>
                  <StackPanel Width="190" Margin="0,0,10,8">
                    <TextBlock Text="가상 CPU" Classes="caption" />
                    <NumericUpDown
                        Value="{Binding CpuCount}"
                        Minimum="2"
                        Maximum="32"
                        AutomationProperties.AutomationId="Setup.CpuCount" />
                  </StackPanel>
                  <StackPanel Width="190" Margin="0,0,0,8">
                    <TextBlock Text="메모리 (MiB)" Classes="caption" />
                    <NumericUpDown
                        Value="{Binding MemoryMiB}"
                        Minimum="4096"
                        Maximum="131072"
                        Increment="1024"
                        AutomationProperties.AutomationId="Setup.Memory" />
                  </StackPanel>
                </WrapPanel>
                <TextBlock
                    Text="{Binding ResourceWarning}"
                    IsVisible="{Binding HasResourceWarning}"
                    Classes="warning"
                    TextWrapping="Wrap" />
              </StackPanel>
            </Expander>
          </Border>

          <Border Classes="card" Padding="0">
            <Expander
                Classes="technical"
                Header="기술 세부정보"
                Margin="12,4"
                AutomationProperties.AutomationId="Setup.Media.TechnicalDetails">
              <Border Classes="subtle-card" Margin="4,8,4,12" Padding="10">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding WindowsMediaPath}" Classes="mono" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding WindowsMediaHash, StringFormat=Windows SHA-256  {0}}" Classes="mono" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding VirtioMediaPath}" Classes="mono" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding VirtioMediaHash, StringFormat=Drivers SHA-256  {0}}" Classes="mono" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </Expander>
          </Border>

          <Button
              Classes="primary"
              Content="Windows 환경 준비하기"
              Command="{Binding PrepareCommand}"
              IsEnabled="{Binding CanPrepare}"
              HorizontalAlignment="Right"
              MinHeight="40"
              MinWidth="180"
              Margin="0,8,0,0"
              IsDefault="True"
              AutomationProperties.AutomationId="Setup.Prepare"
              AutomationProperties.HelpText="선택한 파일로 Windows 환경 준비를 시작합니다." />
        </StackPanel>

        <!-- Running: progress -->
        <StackPanel IsVisible="{Binding IsRunning}" Spacing="20" Margin="0,24,0,0">
          <StackPanel Spacing="8" HorizontalAlignment="Center" MaxWidth="560">
            <TextBlock
                Text="Windows 환경을 준비하고 있습니다"
                Classes="page-title"
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <TextBlock
                Text="앱을 닫아도 다음 실행에서 안전한 지점부터 계속할 수 있습니다."
                Classes="caption"
                TextAlignment="Center"
                TextWrapping="Wrap" />
          </StackPanel>

          <Border Classes="card" Padding="0" MaxWidth="560" HorizontalAlignment="Center">
            <ItemsControl ItemsSource="{Binding Phases}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="phase-row">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                      <Border
                          Width="28"
                          Height="28"
                          CornerRadius="14"
                          Background="{DynamicResource AccentBrush}"
                          IsVisible="{Binding IsCurrent}"
                          VerticalAlignment="Center">
                        <TextBlock
                            Text="{Binding Index}"
                            Foreground="{DynamicResource TextOnAccentBrush}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                      </Border>
                      <Border
                          Width="28"
                          Height="28"
                          CornerRadius="14"
                          BorderBrush="{DynamicResource BorderSubtleBrush}"
                          BorderThickness="1"
                          Background="{DynamicResource SurfaceRaisedBrush}"
                          IsVisible="{Binding !IsCurrent}"
                          VerticalAlignment="Center">
                        <TextBlock
                            Text="{Binding Index}"
                            Classes="caption"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                      </Border>
                      <TextBlock
                          Grid.Column="1"
                          Text="{Binding Title}"
                          Classes="body"
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"
                          IsVisible="{Binding IsCurrent}" />
                      <TextBlock
                          Grid.Column="1"
                          Text="{Binding Title}"
                          Classes="body"
                          VerticalAlignment="Center"
                          IsVisible="{Binding !IsCurrent}" />
                      <StackPanel
                          Grid.Column="2"
                          Orientation="Horizontal"
                          Spacing="6"
                          VerticalAlignment="Center"
                          IsVisible="{Binding IsComplete}">
                        <PathIcon
                            Width="16"
                            Height="16"
                            Foreground="{DynamicResource SuccessBrush}"
                            Data="{StaticResource IconCheckCircle}" />
                        <TextBlock Text="{Binding Marker}" Classes="caption success" VerticalAlignment="Center" />
                      </StackPanel>
                      <StackPanel
                          Grid.Column="2"
                          Orientation="Horizontal"
                          Spacing="6"
                          VerticalAlignment="Center"
                          IsVisible="{Binding IsCurrent}">
                        <PathIcon
                            Width="16"
                            Height="16"
                            Foreground="{DynamicResource AccentBrush}"
                            Data="{StaticResource IconProgress}" />
                        <TextBlock Text="{Binding Marker}" Classes="caption accent" VerticalAlignment="Center" />
                      </StackPanel>
                      <StackPanel
                          Grid.Column="2"
                          Orientation="Horizontal"
                          Spacing="6"
                          VerticalAlignment="Center"
                          IsVisible="{Binding IsPending}">
                        <PathIcon
                            Width="16"
                            Height="16"
                            Foreground="{DynamicResource TextDisabledBrush}"
                            Data="{StaticResource IconCircleOutline}" />
                        <TextBlock Text="{Binding Marker}" Classes="caption muted" VerticalAlignment="Center" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>

          <Border Classes="card" MaxWidth="560" HorizontalAlignment="Center">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" RowDefinitions="Auto,Auto">
              <TextBlock
                  Grid.Column="0"
                  Text="{Binding StatusText}"
                  TextWrapping="Wrap"
                  Classes="body"
                  VerticalAlignment="Center"
                  AutomationProperties.Name="Windows 환경 준비 상태"
                  AutomationProperties.LiveSetting="Polite" />
              <StackPanel
                  Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="8"
                  VerticalAlignment="Center">
                <Button
                    Classes="secondary"
                    Content="설치 화면 보기"
                    Command="{Binding ViewInstallerCommand}"
                    IsEnabled="{Binding CanViewInstaller}"
                    AutomationProperties.AutomationId="Setup.ViewInstaller"
                    AutomationProperties.HelpText="문제를 확인할 때만 Windows 설치 화면을 엽니다." />
                <Button
                    Classes="secondary"
                    Content="안전하게 중단"
                    Command="{Binding CancelCommand}"
                    AutomationProperties.AutomationId="Setup.Cancel" />
              </StackPanel>
              <ProgressBar
                  Grid.Row="1"
                  Grid.ColumnSpan="2"
                  Margin="0,12,0,0"
                  IsIndeterminate="True"
                  AutomationProperties.Name="Windows 환경 준비 진행 중" />
            </Grid>
          </Border>
        </StackPanel>

        <!-- Blocked -->
        <StackPanel
            IsVisible="{Binding IsBlocked}"
            Spacing="16"
            MaxWidth="560"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Margin="0,48,0,0">
          <Border Classes="notice-danger">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
              <PathIcon
                  Width="24"
                  Height="24"
                  Foreground="{DynamicResource DangerBrush}"
                  Data="{StaticResource IconAlert}"
                  VerticalAlignment="Top"
                  Margin="0,2,0,0" />
              <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock Text="{Binding BlockerTitle}" Classes="section-title danger" TextWrapping="Wrap" />
                <TextBlock Text="{Binding BlockerDescription}" Classes="body" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Border>

          <Border IsVisible="{Binding ShowManualCommand}" Classes="card">
            <StackPanel Spacing="8">
              <TextBlock Text="터미널에서 실행할 명령" Classes="caption" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox
                    Text="{Binding ManualInstallCommand}"
                    IsReadOnly="True"
                    Classes="mono"
                    AutomationProperties.AutomationId="Setup.ManualCommand" />
                <Button
                    Grid.Column="1"
                    Classes="secondary"
                    Content="복사"
                    Click="OnCopyManualCommand"
                    AutomationProperties.AutomationId="Setup.CopyManualCommand" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="card" Padding="0">
            <Expander
                Classes="technical"
                Header="기술 세부정보"
                Margin="12,4"
                AutomationProperties.AutomationId="Setup.Blocker.TechnicalDetails">
              <StackPanel Spacing="4" Margin="4,8,4,12">
                <TextBlock Text="{Binding BlockerCode, StringFormat=오류 코드: {0}}" Classes="mono" />
                <TextBlock
                    Text="{Binding TechnicalDetail}"
                    IsVisible="{Binding HasTechnicalDetail}"
                    Classes="mono"
                    TextWrapping="Wrap" />
              </StackPanel>
            </Expander>
          </Border>

          <Button
              Classes="primary"
              Content="{Binding BlockerActionLabel}"
              Command="{Binding RetryCommand}"
              HorizontalAlignment="Right"
              MinHeight="40"
              IsDefault="True"
              AutomationProperties.AutomationId="Setup.Retry" />
        </StackPanel>
      </Grid>
    </ScrollViewer>

    <Border Grid.Row="2" Classes="status-strip" IsVisible="{Binding HasError}">
      <TextBlock
          x:Name="ErrorSummary"
          Text="{Binding ErrorMessage}"
          Classes="danger caption"
          TextWrapping="Wrap"
          Focusable="True"
          AutomationProperties.Name="설치 준비 오류"
          AutomationProperties.LiveSetting="Assertive" />
    </Border>
  </Grid>
</UserControl>
