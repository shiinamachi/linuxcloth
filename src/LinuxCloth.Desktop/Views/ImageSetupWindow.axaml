<Window
    x:Class="LinuxCloth.Desktop.Views.ImageSetupWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="linuxcloth — Windows 기준 이미지 준비"
    Width="920"
    Height="820"
    MinWidth="780"
    MinHeight="680"
    WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0" Padding="26,22" Background="#10172A" BorderBrush="#29324F" BorderThickness="0,0,0,1">
      <StackPanel Spacing="5">
        <TextBlock Text="Windows 기준 이미지 준비" FontSize="24" FontWeight="Bold" />
        <TextBlock
            Classes="muted"
            Text="사용자가 제공한 Windows 11과 virtio-win ISO로 일회용 세션의 읽기 전용 기준 이미지를 만듭니다."
            TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1">
      <StackPanel Margin="26" Spacing="18">
        <Border Classes="card" Padding="18">
          <StackPanel Spacing="13">
            <TextBlock Text="이미지 식별자와 설치 미디어" FontSize="17" FontWeight="Bold" />
            <Grid ColumnDefinitions="170,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="이미지 ID" Classes="muted" VerticalAlignment="Center" />
              <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding ImageIdText}" PlaceholderText="windows-11" IsReadOnly="{Binding IsBuilding}" />

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Windows 11 x64 ISO" Classes="muted" VerticalAlignment="Center" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding WindowsIsoPath}" PlaceholderText="/절대/경로/windows.iso" IsReadOnly="{Binding IsBuilding}" />
              <Button Grid.Row="1" Grid.Column="2" Classes="secondary" Content="찾기" Click="OnBrowseWindowsIso" IsEnabled="{Binding !IsBuilding}" />

              <TextBlock Grid.Row="2" Grid.Column="0" Text="virtio-win ISO" Classes="muted" VerticalAlignment="Center" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding VirtioWinIsoPath}" PlaceholderText="/절대/경로/virtio-win.iso" IsReadOnly="{Binding IsBuilding}" />
              <Button Grid.Row="2" Grid.Column="2" Classes="secondary" Content="찾기" Click="OnBrowseVirtioIso" IsEnabled="{Binding !IsBuilding}" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="card" Padding="18">
          <StackPanel Spacing="13">
            <TextBlock Text="Secure Boot 펌웨어와 게스트 브리지" FontSize="17" FontWeight="Bold" />
            <Grid ColumnDefinitions="170,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="OVMF 코드" Classes="muted" VerticalAlignment="Center" />
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding OvmfCodePath}" PlaceholderText="OVMF_CODE.secboot.fd" IsReadOnly="{Binding IsBuilding}" />
              <Button Grid.Row="0" Grid.Column="2" Classes="secondary" Content="찾기" Click="OnBrowseOvmfCode" IsEnabled="{Binding !IsBuilding}" />

              <TextBlock Grid.Row="1" Grid.Column="0" Text="OVMF 변수 템플릿" Classes="muted" VerticalAlignment="Center" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OvmfVariablesTemplatePath}" PlaceholderText="OVMF_VARS.fd" IsReadOnly="{Binding IsBuilding}" />
              <Button Grid.Row="1" Grid.Column="2" Classes="secondary" Content="찾기" Click="OnBrowseOvmfVariables" IsEnabled="{Binding !IsBuilding}" />

              <TextBlock Grid.Row="2" Grid.Column="0" Text="GuestBridge" Classes="muted" VerticalAlignment="Center" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding GuestBridgeExecutablePath}" PlaceholderText="linuxcloth-guest-bridge.exe" IsReadOnly="{Binding IsBuilding}" />
              <Button Grid.Row="2" Grid.Column="2" Classes="secondary" Content="찾기" Click="OnBrowseGuestBridge" IsEnabled="{Binding !IsBuilding}" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="card" Padding="18">
          <StackPanel Spacing="13">
            <TextBlock Text="가상 머신 리소스" FontSize="17" FontWeight="Bold" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
              <StackPanel Grid.Column="0" Spacing="5">
                <TextBlock Text="디스크 (GiB)" Classes="muted" />
                <NumericUpDown Value="{Binding DiskSizeGiB}" Minimum="64" Maximum="1024" Increment="8" FormatString="0" IsEnabled="{Binding !IsBuilding}" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="5">
                <TextBlock Text="가상 CPU" Classes="muted" />
                <NumericUpDown Value="{Binding CpuCount}" Minimum="2" Maximum="32" Increment="1" FormatString="0" IsEnabled="{Binding !IsBuilding}" />
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="5">
                <TextBlock Text="메모리 (MiB)" Classes="muted" />
                <NumericUpDown Value="{Binding MemoryMiB}" Minimum="4096" Maximum="131072" Increment="1024" FormatString="0" IsEnabled="{Binding !IsBuilding}" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Border Background="#332D1D" BorderBrush="#695C2A" BorderThickness="1" CornerRadius="12" Padding="15">
          <TextBlock
              Text="설치 중 별도의 Windows 창이 열립니다. Windows 설치가 종료된 뒤 linuxcloth가 미디어 없는 두 번째 부팅에서 GuestBridge를 검증합니다. Windows ISO나 생성된 이미지는 프로젝트에 업로드되지 않습니다."
              TextWrapping="Wrap" />
        </Border>

        <Border Classes="card" Padding="18">
          <StackPanel Spacing="11">
            <TextBlock Text="진행 상태와 재개" FontSize="17" FontWeight="Bold" />
            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBuilding}" Height="5" />
            <TextBlock Text="{Binding BuildStatus}" TextWrapping="Wrap" />
            <TextBlock Text="보존된 스테이징 경로" Classes="muted" FontSize="11" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <TextBox Grid.Column="0" Text="{Binding StagingDirectory}" PlaceholderText="취소·중단된 빌드의 .staging-... 디렉터리" IsReadOnly="{Binding IsBuilding}" />
              <Button Grid.Column="1" Classes="secondary" Content="폴더 찾기" Click="OnBrowseStagingDirectory" IsEnabled="{Binding !IsBuilding}" />
            </Grid>
            <TextBlock
                Text="{Binding ErrorMessage}"
                IsVisible="{Binding HasError}"
                Foreground="#FF9E9E"
                TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2" Padding="22,15" Background="#10172A" BorderBrush="#29324F" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
        <Button Grid.Column="0" Classes="secondary" Content="닫기" Click="OnClose" />
        <Button Grid.Column="2" Classes="secondary" Content="보존 상태에서 다시 시작" Command="{Binding ResumeBuildCommand}" IsEnabled="{Binding CanResumeBuild}" />
        <Button Grid.Column="3" Classes="primary" Content="새 기준 이미지 만들기" Command="{Binding StartBuildCommand}" IsEnabled="{Binding CanStartBuild}" IsVisible="{Binding !IsBuilding}" />
        <Button Grid.Column="3" Classes="secondary" Content="안전하게 취소" Command="{Binding CancelBuildCommand}" IsVisible="{Binding IsBuilding}" />
      </Grid>
    </Border>
  </Grid>
</Window>
