<UserControl
    x:Class="LinuxCloth.Desktop.Views.RecoveryView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:localization="using:LinuxCloth.Desktop.Localization"
    Background="{DynamicResource AppBackgroundBrush}">
  <Border Padding="32">
    <Border
        Classes="card"
        MaxWidth="520"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Padding="0">
      <StackPanel>
        <StackPanel Spacing="12" Margin="32,28,32,20" HorizontalAlignment="Stretch">
          <PathIcon
              Width="48"
              Height="48"
              HorizontalAlignment="Center"
              Foreground="{DynamicResource WarningBrush}"
              Data="{StaticResource IconShieldRefresh}" />
          <TextBlock
              Text="{Binding [Recovery.Title], Source={x:Static localization:UiStrings.Instance}}"
              Classes="dialog-title"
              TextAlignment="Center"
              TextWrapping="Wrap" />
          <TextBlock
              Text="{Binding [Recovery.Description], Source={x:Static localization:UiStrings.Instance}}"
              Classes="body muted"
              TextAlignment="Center"
              TextWrapping="Wrap" />
        </StackPanel>

        <Border BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0" Padding="20,12,20,20">
          <StackPanel Spacing="12">
            <Expander
                x:Name="TechnicalDetails"
                Classes="technical"
                Header="{Binding [Recovery.TechnicalDetails], Source={x:Static localization:UiStrings.Instance}}"
                AutomationProperties.AutomationId="Recovery.TechnicalDetails">
              <TextBlock
                  x:Name="DetailsText"
                  Classes="caption mono"
                  TextWrapping="Wrap"
                  Margin="0,6,0,0" />
            </Expander>
            <Button
                x:Name="RetryButton"
                Classes="primary"
                Content="{Binding [Recovery.Retry], Source={x:Static localization:UiStrings.Instance}}"
                HorizontalAlignment="Left"
                AutomationProperties.AutomationId="Recovery.Retry" />
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>
  </Border>
</UserControl>
