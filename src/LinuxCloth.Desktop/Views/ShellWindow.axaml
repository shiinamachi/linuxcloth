<Window
    x:Class="LinuxCloth.Desktop.Views.ShellWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="linuxcloth"
    Width="1280"
    Height="820"
    MinWidth="720"
    MinHeight="480"
    WindowStartupLocation="CenterScreen">
  <Grid>
    <ContentControl x:Name="ShellContent" />
    <Border x:Name="StartupPanel" Background="{DynamicResource AppBackgroundBrush}" IsVisible="True">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" MaxWidth="360">
        <Border Width="56" Height="56" CornerRadius="16" Background="{DynamicResource AccentBrush}" HorizontalAlignment="Center">
          <TextBlock
              Text="lc"
              Foreground="{DynamicResource TextOnAccentBrush}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              FontSize="18"
              FontWeight="Bold" />
        </Border>
        <TextBlock
            x:Name="StartupStatus"
            Text="준비 중…"
            Classes="muted"
            TextWrapping="Wrap"
            TextAlignment="Center"
            FontSize="13" />
        <ProgressBar
            Width="180"
            Height="4"
            IsIndeterminate="True"
            HorizontalAlignment="Center"
            AutomationProperties.Name="시작 준비 진행 중" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
