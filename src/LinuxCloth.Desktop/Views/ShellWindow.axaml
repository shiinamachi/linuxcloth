<Window
    x:Class="LinuxCloth.Desktop.Views.ShellWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="linuxcloth"
    Width="1280"
    Height="820"
    MinWidth="720"
    MinHeight="480"
    WindowStartupLocation="CenterScreen">
  <Grid>
    <ContentControl x:Name="ShellContent" />
    <Border x:Name="StartupPanel" Background="{DynamicResource AppBackgroundBrush}" IsVisible="True" Padding="32">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20" MaxWidth="520">
        <Border Width="64" Height="64" CornerRadius="20" Background="{DynamicResource AccentBrush}">
          <TextBlock Text="lc" Foreground="{DynamicResource TextOnAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="21" FontWeight="Bold" />
        </Border>
        <StackPanel Spacing="6">
          <TextBlock Text="linuxcloth를 준비하고 있습니다" Classes="page-title" FontSize="24" HorizontalAlignment="Center" />
          <TextBlock x:Name="StartupStatus" Text="이전 작업과 실행 환경을 확인하고 있습니다…" Classes="muted" TextWrapping="Wrap" TextAlignment="Center" />
        </StackPanel>
        <ProgressBar Width="240" IsIndeterminate="True" AutomationProperties.Name="시작 준비 진행 중" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
