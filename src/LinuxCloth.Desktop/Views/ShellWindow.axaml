<Window
    x:Class="LinuxCloth.Desktop.Views.ShellWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="linuxcloth"
    Width="1000"
    Height="700"
    MinWidth="720"
    MinHeight="480"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource AppBackgroundBrush}">
  <Grid>
    <ContentControl x:Name="ShellContent" />
    <Border x:Name="StartupPanel" Background="{DynamicResource AppBackgroundBrush}" IsVisible="True">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" MaxWidth="360">
        <TextBlock
            Text="linuxcloth"
            FontSize="22"
            FontWeight="Bold"
            HorizontalAlignment="Center" />
        <TextBlock
            x:Name="StartupStatus"
            Text="준비 중…"
            Classes="muted"
            TextWrapping="Wrap"
            TextAlignment="Center"
            FontSize="13" />
        <ProgressBar
            Width="200"
            Height="4"
            IsIndeterminate="True"
            HorizontalAlignment="Center"
            AutomationProperties.Name="시작 준비 진행 중" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
