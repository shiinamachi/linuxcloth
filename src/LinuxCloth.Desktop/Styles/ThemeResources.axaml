<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- TableCloth-inspired Windows utility palette: cool gray canvas, system-blue selection. -->
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F8F8F8" />
      <SolidColorBrush x:Key="SurfaceBrush" Color="#F5F5F5" />
      <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="SurfaceSubtleBrush" Color="#EFEFEF" />
      <SolidColorBrush x:Key="SurfaceOverlayBrush" Color="#F0F0F0" />
      <SolidColorBrush x:Key="CatalogLogoBackgroundBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="TextPrimaryBrush" Color="#040404" />
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="#606060" />
      <SolidColorBrush x:Key="TextDisabledBrush" Color="#9A9A9A" />
      <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="BorderSubtleBrush" Color="#E0E0E0" />
      <SolidColorBrush x:Key="BorderStrongBrush" Color="#ACACAC" />
      <!-- Windows-like selection blue; dark enough for white label text -->
      <SolidColorBrush x:Key="AccentBrush" Color="#0078D4" />
      <SolidColorBrush x:Key="AccentHoverBrush" Color="#106EBE" />
      <SolidColorBrush x:Key="AccentPressedBrush" Color="#005A9E" />
      <SolidColorBrush x:Key="AccentSoftBrush" Color="#D6EBFA" />
      <SolidColorBrush x:Key="SelectionBorderBrush" Color="#26A0DA" />
      <SolidColorBrush x:Key="SuccessBrush" Color="#0B6A0B" />
      <SolidColorBrush x:Key="SuccessSoftBrush" Color="#E6F4E6" />
      <SolidColorBrush x:Key="WarningBrush" Color="#9A5B00" />
      <SolidColorBrush x:Key="WarningSoftBrush" Color="#FFF4D6" />
      <SolidColorBrush x:Key="DangerBrush" Color="#C42B1C" />
      <SolidColorBrush x:Key="DangerSoftBrush" Color="#FDE7E9" />
      <SolidColorBrush x:Key="InfoBrush" Color="#1D4ED8" />
      <SolidColorBrush x:Key="InfoSoftBrush" Color="#EFF6FF" />
      <SolidColorBrush x:Key="FocusRingBrush" Color="#26A0DA" />
      <SolidColorBrush x:Key="ScrimBrush" Color="#66000000" />
    </ResourceDictionary>

    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1E1E1E" />
      <SolidColorBrush x:Key="SurfaceBrush" Color="#252526" />
      <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#2D2D30" />
      <SolidColorBrush x:Key="SurfaceSubtleBrush" Color="#333337" />
      <SolidColorBrush x:Key="SurfaceOverlayBrush" Color="#3E3E42" />
      <SolidColorBrush x:Key="CatalogLogoBackgroundBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F3F3F3" />
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0A0" />
      <SolidColorBrush x:Key="TextDisabledBrush" Color="#6D6D6D" />
      <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="BorderSubtleBrush" Color="#3F3F46" />
      <SolidColorBrush x:Key="BorderStrongBrush" Color="#6B6B6B" />
      <SolidColorBrush x:Key="AccentBrush" Color="#0078D4" />
      <SolidColorBrush x:Key="AccentHoverBrush" Color="#1C86D9" />
      <SolidColorBrush x:Key="AccentPressedBrush" Color="#005A9E" />
      <SolidColorBrush x:Key="AccentSoftBrush" Color="#0C3B5E" />
      <SolidColorBrush x:Key="SelectionBorderBrush" Color="#26A0DA" />
      <SolidColorBrush x:Key="SuccessBrush" Color="#6CCB5F" />
      <SolidColorBrush x:Key="SuccessSoftBrush" Color="#1B3A1B" />
      <SolidColorBrush x:Key="WarningBrush" Color="#F0C36A" />
      <SolidColorBrush x:Key="WarningSoftBrush" Color="#3A2E12" />
      <SolidColorBrush x:Key="DangerBrush" Color="#F1707A" />
      <SolidColorBrush x:Key="DangerSoftBrush" Color="#3B1A1D" />
      <SolidColorBrush x:Key="InfoBrush" Color="#6CB6FF" />
      <SolidColorBrush x:Key="InfoSoftBrush" Color="#1A2B40" />
      <SolidColorBrush x:Key="FocusRingBrush" Color="#60CDFF" />
      <SolidColorBrush x:Key="ScrimBrush" Color="#99000000" />
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

  <x:Double x:Key="Space1">4</x:Double>
  <x:Double x:Key="Space2">8</x:Double>
  <x:Double x:Key="Space3">12</x:Double>
  <x:Double x:Key="Space4">16</x:Double>
  <x:Double x:Key="Space5">24</x:Double>
  <x:Double x:Key="Space6">32</x:Double>
  <CornerRadius x:Key="CornerSmall">2</CornerRadius>
  <CornerRadius x:Key="CornerMedium">3</CornerRadius>
  <CornerRadius x:Key="CornerLarge">4</CornerRadius>

