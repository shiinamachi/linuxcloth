  <StreamGeometry x:Key="IconAlert">M12,2 L1,21 L23,21 Z M13,18 L11,18 L11,16 L13,16 Z M13,14 L11,14 L11,10 L13,10 Z</StreamGeometry>
  <StreamGeometry x:Key="IconPlus">M19,13 L13,13 L13,19 L11,19 L11,13 L5,13 L5,11 L11,11 L11,5 L13,5 L13,11 L19,11 Z</StreamGeometry>
</ResourceDictionary>
