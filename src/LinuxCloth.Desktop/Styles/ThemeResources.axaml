      <SolidColorBrush x:Key="AccentSoftBrush" Color="#CCFBF1" />
      <SolidColorBrush x:Key="SuccessBrush" Color="#047857" />
      <SolidColorBrush x:Key="SuccessSoftBrush" Color="#D1FAE5" />
      <SolidColorBrush x:Key="WarningBrush" Color="#B45309" />
      <SolidColorBrush x:Key="WarningSoftBrush" Color="#FEF3C7" />
      <SolidColorBrush x:Key="DangerBrush" Color="#B91C1C" />
      <SolidColorBrush x:Key="DangerSoftBrush" Color="#FEE2E2" />
      <SolidColorBrush x:Key="InfoBrush" Color="#1D4ED8" />
