      <SolidColorBrush x:Key="NavTextBrush" Color="#F8FAFC" />
      <SolidColorBrush x:Key="NavTextMutedBrush" Color="#94A3B8" />
      <SolidColorBrush x:Key="CatalogLogoBackgroundBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" />
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="#475569" />
      <SolidColorBrush x:Key="TextDisabledBrush" Color="#94A3B8" />
      <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FFFFFF" />
