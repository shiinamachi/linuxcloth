<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Flat Windows utility controls: design tokens from docs/design. -->

  <Style Selector="Window">
    <Setter Property="FontFamily" Value="Segoe UI, Inter, Noto Sans CJK KR, Noto Sans, sans-serif" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="UserControl">
    <Setter Property="FontFamily" Value="Segoe UI, Inter, Noto Sans CJK KR, Noto Sans, sans-serif" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <!-- Typography: title 24–28 · section 18–20 · body 14 · caption 12 · meta 11 -->
  <Style Selector="TextBlock.page-title">
    <Setter Property="FontSize" Value="26" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>
  <Style Selector="TextBlock.dialog-title">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>
  <Style Selector="TextBlock.brand-title">
    <Setter Property="FontSize" Value="28" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>
  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>
  <Style Selector="TextBlock.instruction">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>
  <Style Selector="TextBlock.body">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>
  <Style Selector="TextBlock.caption">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>
  <Style Selector="TextBlock.meta">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>
  <Style Selector="TextBlock.eyebrow">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>
  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>
  <Style Selector="TextBlock.danger">
    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
  </Style>
  <Style Selector="TextBlock.success">
    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
  </Style>
  <Style Selector="TextBlock.warning">
    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
  </Style>
  <Style Selector="TextBlock.accent">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
  </Style>
  <Style Selector="TextBlock.mono">
    <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="Button">
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="MinWidth" Value="80" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerSmall}" />
    <Setter Property="Padding" Value="14,6" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <Style Selector="Button.primary:pointerover">
    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
  </Style>
  <Style Selector="Button.primary:pressed">
    <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentPressedBrush}" />
  </Style>
  <Style Selector="Button.primary:disabled">
    <Setter Property="Opacity" Value="0.5" />
  </Style>
  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <Style Selector="Button.secondary:pointerover">
    <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
  </Style>
  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="MinWidth" Value="0" />
  </Style>
  <Style Selector="Button.ghost:pointerover">
    <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
  </Style>
  <Style Selector="Button.danger">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <Style Selector="Button.danger:pointerover">
    <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
  </Style>
  <Style Selector="Button.icon">
    <Setter Property="Width" Value="32" />
    <Setter Property="MinWidth" Value="32" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="6" />
  </Style>
  <Style Selector="Button.icon-sm">
    <Setter Property="Width" Value="28" />
    <Setter Property="MinWidth" Value="28" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Padding" Value="4" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerLarge}" />
    <Setter Property="Padding" Value="16" />
  </Style>
  <Style Selector="Border.subtle-card">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerSmall}" />
    <Setter Property="Padding" Value="12" />
  </Style>
  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
  </Style>
  <Style Selector="Border.chrome-bar">
    <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,0" />
    <Setter Property="Padding" Value="24,16,24,8" />
  </Style>
  <Style Selector="Border.status-strip">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="Padding" Value="12,8" />
  </Style>
  <Style Selector="Border.notice-info">
    <Setter Property="Background" Value="{DynamicResource InfoSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerLarge}" />
    <Setter Property="Padding" Value="12" />
  </Style>
  <Style Selector="Border.notice-warning">
    <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerLarge}" />
    <Setter Property="Padding" Value="12" />
  </Style>
  <Style Selector="Border.notice-danger">
    <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerLarge}" />
    <Setter Property="Padding" Value="16" />
  </Style>
  <Style Selector="Border.badge">
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerSmall}" />
    <Setter Property="Padding" Value="8,3" />
  </Style>
  <Style Selector="Border.badge-success">
    <Setter Property="Background" Value="{DynamicResource SuccessSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerSmall}" />
    <Setter Property="Padding" Value="8,3" />
  </Style>
  <Style Selector="Border.badge-warning">
    <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerSmall}" />
    <Setter Property="Padding" Value="8,3" />
  </Style>
  <Style Selector="Border.badge-danger">
    <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerSmall}" />
    <Setter Property="Padding" Value="8,3" />
  </Style>
  <Style Selector="Border.badge-neutral">
    <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerSmall}" />
    <Setter Property="Padding" Value="8,3" />
  </Style>
  <Style Selector="Border.search-field">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerLarge}" />
    <Setter Property="MinHeight" Value="36" />
  </Style>
  <Style Selector="Border.logo-frame">
    <Setter Property="Background" Value="{DynamicResource CatalogLogoBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerLarge}" />
    <Setter Property="Padding" Value="8" />
  </Style>
  <Style Selector="Border.phase-row">
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="12,10" />
  </Style>
  <Style Selector="Border.form-row">
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="12,10" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerSmall}" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="FontSize" Value="14" />
  </Style>
  <Style Selector="TextBox.search">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4,4" />
  </Style>
  <Style Selector="CheckBox">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="FontSize" Value="14" />
  </Style>
  <Style Selector="NumericUpDown">
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerSmall}" />
  </Style>
  <Style Selector="ComboBox">
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerSmall}" />
    <Setter Property="FontSize" Value="14" />
  </Style>
  <Style Selector="Expander.technical">
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="FontSize" Value="13" />
  </Style>
  <Style Selector="ProgressBar">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
    <Setter Property="MinHeight" Value="4" />
    <Setter Property="Height" Value="4" />
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="ListBox.category-list">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="ListBox.category-list > ListBoxItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="Margin" Value="4,2" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerSmall}" />
  </Style>
  <Style Selector="ListBox.category-list > ListBoxItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
  </Style>
  <Style Selector="ListBox.category-list > ListBoxItem:selected">
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
  </Style>
  <Style Selector="ListBox.category-list > ListBoxItem:selected TextBlock.category-label">
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="ListBox.category-list > ListBoxItem:selected Ellipse.category-radio">
    <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Stroke" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="ListBox.service-grid">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="ListBox.service-grid > ListBoxItem">
    <Setter Property="Width" Value="88" />
    <Setter Property="MinHeight" Value="100" />
    <Setter Property="Padding" Value="6,8" />
    <Setter Property="Margin" Value="4" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Top" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerLarge}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>
  <Style Selector="ListBox.service-grid > ListBoxItem:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource SelectionBorderBrush}" />
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
  </Style>
  <Style Selector="ListBox.service-grid > ListBoxItem:selected">
    <Setter Property="BorderBrush" Value="{DynamicResource SelectionBorderBrush}" />
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
  </Style>

  <Style Selector="ListBox.form-list">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerLarge}" />
  </Style>
</Styles>
