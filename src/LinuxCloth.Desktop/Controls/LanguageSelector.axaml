<UserControl
    x:Class="LinuxCloth.Desktop.Controls.LanguageSelector"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:localization="using:LinuxCloth.Desktop.Localization">
  <ComboBox
      x:Name="LanguageComboBox"
      MinWidth="132"
      ItemsSource="{Binding Languages, Source={x:Static localization:UiStrings.Instance}}"
      SelectedItem="{Binding SelectedLanguage, Source={x:Static localization:UiStrings.Instance}, Mode=TwoWay}"
      AutomationProperties.AutomationId="Shell.Language"
      AutomationProperties.Name="{Binding [Language.Selector], Source={x:Static localization:UiStrings.Instance}}">
    <ComboBox.ItemTemplate>
      <DataTemplate>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <PathIcon
              Width="16"
              Height="16"
              Data="{StaticResource IconGlobe}"
              Foreground="{DynamicResource TextPrimaryBrush}"
              VerticalAlignment="Center" />
          <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
        </StackPanel>
      </DataTemplate>
    </ComboBox.ItemTemplate>
  </ComboBox>
</UserControl>
