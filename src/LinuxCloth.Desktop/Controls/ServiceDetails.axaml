<UserControl
    x:Class="LinuxCloth.Desktop.Controls.ServiceDetails"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- TableCloth DetailPage-inspired form: logo, title, launch, options. -->
  <Grid RowDefinitions="*,Auto">
    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="10">
        <Grid ColumnDefinitions="96,*" ColumnSpacing="8">
          <Border
              Width="88"
              Height="88"
              Background="{DynamicResource CatalogLogoBackgroundBrush}"
              BorderBrush="{DynamicResource BorderSubtleBrush}"
              BorderThickness="1"
              Padding="6"
              HorizontalAlignment="Left"
              VerticalAlignment="Top">
            <Image Source="{Binding SelectedService.Image}" Stretch="Uniform" />
          </Border>
          <StackPanel Grid.Column="1" Spacing="6">
            <TextBlock
                Text="{Binding SelectedService.DisplayName}"
                FontSize="22"
                FontWeight="Bold"
                TextWrapping="Wrap"
                TextTrimming="CharacterEllipsis" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Border Classes="badge-success" IsVisible="{Binding SelectedService.IsVerified}">
                <TextBlock Text="{Binding SelectedService.CompatibilityLabel}" FontSize="11" Foreground="{DynamicResource SuccessBrush}" />
              </Border>
              <Border Classes="badge-warning" IsVisible="{Binding SelectedService.IsPartial}">
                <TextBlock Text="{Binding SelectedService.CompatibilityLabel}" FontSize="11" Foreground="{DynamicResource WarningBrush}" />
              </Border>
              <Border Classes="badge-danger" IsVisible="{Binding SelectedService.IsBlocked}">
                <TextBlock Text="{Binding SelectedService.CompatibilityLabel}" FontSize="11" Foreground="{DynamicResource DangerBrush}" />
              </Border>
              <Border Classes="badge-neutral" IsVisible="{Binding SelectedService.IsUnknown}">
                <TextBlock Text="{Binding SelectedService.CompatibilityLabel}" FontSize="11" Classes="muted" />
              </Border>
              <TextBlock Text="{Binding SelectedService.Category}" Classes="muted" FontSize="12" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock
                Text="{Binding SelectedService.Url}"
                Classes="muted"
                FontSize="12"
                TextWrapping="Wrap" />
          </StackPanel>
        </Grid>

        <TextBlock
            Text="{Binding SelectedService.CompatibilityDescription}"
            TextWrapping="Wrap"
            FontSize="12"
            Classes="muted" />

        <Border Classes="notice-warning" Padding="8">
          <TextBlock
              Text="닫으면 이번 실행의 파일과 변경사항이 삭제됩니다."
              TextWrapping="Wrap"
              FontSize="12"
              FontWeight="Bold"
              Foreground="{DynamicResource WarningBrush}" />
        </Border>

        <StackPanel Spacing="4">
          <TextBlock Text="Windows 환경" FontWeight="Bold" FontSize="12" />
          <ComboBox
              ItemsSource="{Binding Images}"
              SelectedItem="{Binding SelectedImage}"
              HorizontalAlignment="Stretch"
              AutomationProperties.AutomationId="Catalog.Details.WindowsEnvironment"
              AutomationProperties.Name="서비스를 열 Windows 환경">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button
              IsVisible="{Binding !HasImages}"
              Classes="secondary"
              Content="Windows 환경 준비"
              Click="OnOpenSetup"
              AutomationProperties.AutomationId="Catalog.Details.PrepareWindowsEnvironment"
              HorizontalAlignment="Left" />
        </StackPanel>

        <Expander
            Classes="technical"
            Header="기술 세부정보"
            AutomationProperties.AutomationId="Catalog.Details.TechnicalDetails">
          <StackPanel Spacing="8" Margin="0,8,0,0">
            <StackPanel Spacing="2">
              <TextBlock Text="영문 이름" Classes="muted" FontSize="11" />
              <TextBlock Text="{Binding SelectedService.EnglishDisplayName}" TextWrapping="Wrap" FontSize="12" />
            </StackPanel>
            <StackPanel Spacing="2">
              <TextBlock Text="실행 구성" Classes="muted" FontSize="11" />
              <TextBlock Text="{Binding SelectedService.PackageSummary}" TextWrapping="Wrap" FontSize="12" />
            </StackPanel>
            <TextBlock
                IsVisible="{Binding SelectedService.HasCustomBootstrap}"
                Text="추가 준비 단계를 사용합니다."
                TextWrapping="Wrap"
                Classes="muted"
                FontSize="12" />
          </StackPanel>
        </Expander>
      </StackPanel>
    </ScrollViewer>

    <Button
        Grid.Row="1"
        Classes="primary"
        Margin="0,12,0,0"
        MinHeight="32"
        Content="실행하기"
        Command="{Binding LaunchCommand}"
        IsEnabled="{Binding CanLaunch}"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Center"
        AutomationProperties.AutomationId="Catalog.Launch"
        AutomationProperties.Name="선택한 서비스 열기" />
  </Grid>
</UserControl>
