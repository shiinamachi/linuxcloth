<UserControl
    x:Class="LinuxCloth.Desktop.Controls.ServiceDetails"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="*,Auto">
    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="18">
        <Grid ColumnDefinitions="76,*">
          <Border Grid.Column="0" Width="68" Height="68" CornerRadius="16" Background="{DynamicResource CatalogLogoBackgroundBrush}" Padding="8" HorizontalAlignment="Left">
            <Image Source="{Binding SelectedService.Image}" Stretch="Uniform" />
          </Border>
          <StackPanel Grid.Column="1" Margin="12,2,0,0" Spacing="4">
            <TextBlock Text="{Binding SelectedService.DisplayName}" FontSize="23" FontWeight="Bold" TextWrapping="Wrap" />
            <TextBlock Text="{Binding SelectedService.EnglishDisplayName}" Classes="muted" TextWrapping="Wrap" />
          </StackPanel>
        </Grid>

        <Border Classes="badge" HorizontalAlignment="Left">
          <TextBlock Text="{Binding SelectedService.CompatibilityLabel}" FontWeight="SemiBold" FontSize="11" />
        </Border>

        <StackPanel Spacing="6">
          <TextBlock Text="이용 안내" Classes="eyebrow" />
          <TextBlock Text="{Binding SelectedService.CompatibilityDescription}" TextWrapping="Wrap" />
        </StackPanel>

        <Border Classes="subtle-card" Padding="14">
          <StackPanel Spacing="6">
            <TextBlock Text="사용 후 변경사항이 삭제됩니다" FontWeight="SemiBold" />
            <TextBlock Text="서비스는 별도의 Windows 환경에서 열립니다. 환경을 닫으면 이번 실행 중 저장한 파일과 변경사항이 삭제됩니다." Classes="muted" TextWrapping="Wrap" FontSize="12" />
          </StackPanel>
        </Border>

        <StackPanel Spacing="7">
          <TextBlock Text="Windows 환경" Classes="eyebrow" />
          <ComboBox ItemsSource="{Binding Images}" SelectedItem="{Binding SelectedImage}" AutomationProperties.AutomationId="Catalog.Details.WindowsEnvironment" AutomationProperties.Name="서비스를 열 Windows 환경">
            <ComboBox.ItemTemplate>
              <DataTemplate><TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" /></DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button
              IsVisible="{Binding !HasImages}"
              Classes="secondary"
              Content="Windows 환경 준비"
              Click="OnOpenSetup"
              AutomationProperties.AutomationId="Catalog.Details.PrepareWindowsEnvironment"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center" />
        </StackPanel>

        <Expander Classes="technical" Header="기술 세부정보" AutomationProperties.AutomationId="Catalog.Details.TechnicalDetails">
          <StackPanel Spacing="12" Margin="0,10,0,0">
            <StackPanel Spacing="4">
              <TextBlock Text="공식 주소" Classes="eyebrow" />
              <TextBlock Text="{Binding SelectedService.Url}" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="실행 구성" Classes="eyebrow" />
              <TextBlock Text="{Binding SelectedService.PackageSummary}" TextWrapping="Wrap" />
            </StackPanel>
            <TextBlock
                IsVisible="{Binding SelectedService.HasCustomBootstrap}"
                Text="이 서비스는 공식 카탈로그의 추가 준비 단계를 사용합니다."
                TextWrapping="Wrap" />
          </StackPanel>
        </Expander>
      </StackPanel>
    </ScrollViewer>

    <Button
        Grid.Row="1"
        Classes="primary"
        Margin="0,20,0,0"
        Content="서비스 열기"
        Command="{Binding LaunchCommand}"
        IsEnabled="{Binding CanLaunch}"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Center"
        AutomationProperties.AutomationId="Catalog.Launch"
        AutomationProperties.Name="선택한 서비스 열기" />
  </Grid>
</UserControl>
