<UserControl
    x:Class="LinuxCloth.Desktop.Controls.ServiceDetails"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="*,Auto">
    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="18">
        <StackPanel Spacing="14" HorizontalAlignment="Stretch">
          <Border
              Width="88"
              Height="88"
              CornerRadius="24"
              Background="{DynamicResource CatalogLogoBackgroundBrush}"
              BorderBrush="{DynamicResource BorderSubtleBrush}"
              BorderThickness="1"
              Padding="12"
              HorizontalAlignment="Center">
            <Image Source="{Binding SelectedService.Image}" Stretch="Uniform" />
          </Border>
          <StackPanel Spacing="8" HorizontalAlignment="Stretch">
            <TextBlock
                Text="{Binding SelectedService.DisplayName}"
                FontSize="22"
                FontWeight="Bold"
                TextAlignment="Center"
                TextWrapping="Wrap"
                LetterSpacing="-0.3" />
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
              <Border Classes="badge-success" IsVisible="{Binding SelectedService.IsVerified}">
                <TextBlock Text="{Binding SelectedService.CompatibilityLabel}" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource SuccessBrush}" />
              </Border>
              <Border Classes="badge-warning" IsVisible="{Binding SelectedService.IsPartial}">
                <TextBlock Text="{Binding SelectedService.CompatibilityLabel}" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource WarningBrush}" />
              </Border>
              <Border Classes="badge-danger" IsVisible="{Binding SelectedService.IsBlocked}">
                <TextBlock Text="{Binding SelectedService.CompatibilityLabel}" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource DangerBrush}" />
              </Border>
              <Border Classes="badge-neutral" IsVisible="{Binding SelectedService.IsUnknown}">
                <TextBlock Text="{Binding SelectedService.CompatibilityLabel}" FontWeight="Bold" FontSize="11" Classes="muted" />
              </Border>
              <TextBlock
                  Text="{Binding SelectedService.Category}"
                  Classes="muted"
                  FontSize="12"
                  VerticalAlignment="Center" />
            </StackPanel>
          </StackPanel>
        </StackPanel>

        <TextBlock
            Text="{Binding SelectedService.CompatibilityDescription}"
            TextWrapping="Wrap"
            TextAlignment="Center"
            Classes="muted"
            FontSize="13" />

        <Border Classes="notice-warning" Padding="14,12">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <PathIcon
                Width="16"
                Height="16"
                Data="{StaticResource IconAlert}"
                Foreground="{DynamicResource WarningBrush}"
                VerticalAlignment="Center" />
            <TextBlock
                Text="닫으면 이번 실행의 파일과 변경사항이 삭제됩니다."
                TextWrapping="Wrap"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{DynamicResource WarningBrush}" />
          </StackPanel>
        </Border>

        <StackPanel Spacing="8">
          <TextBlock Text="WINDOWS 환경" Classes="eyebrow" />
          <ComboBox
              ItemsSource="{Binding Images}"
              SelectedItem="{Binding SelectedImage}"
              HorizontalAlignment="Stretch"
              AutomationProperties.AutomationId="Catalog.Details.WindowsEnvironment"
              AutomationProperties.Name="서비스를 열 Windows 환경">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button
              IsVisible="{Binding !HasImages}"
              Classes="secondary"
              Content="Windows 환경 준비"
              Click="OnOpenSetup"
              AutomationProperties.AutomationId="Catalog.Details.PrepareWindowsEnvironment"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center" />
        </StackPanel>

        <Expander
            Classes="technical"
            Header="기술 세부정보"
            AutomationProperties.AutomationId="Catalog.Details.TechnicalDetails">
          <StackPanel Spacing="10" Margin="0,10,0,0">
            <StackPanel Spacing="2">
              <TextBlock Text="영문 이름" Classes="eyebrow" />
              <TextBlock Text="{Binding SelectedService.EnglishDisplayName}" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Spacing="2">
              <TextBlock Text="공식 주소" Classes="eyebrow" />
              <TextBlock Text="{Binding SelectedService.Url}" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Spacing="2">
              <TextBlock Text="실행 구성" Classes="eyebrow" />
              <TextBlock Text="{Binding SelectedService.PackageSummary}" TextWrapping="Wrap" />
            </StackPanel>
            <TextBlock
                IsVisible="{Binding SelectedService.HasCustomBootstrap}"
                Text="추가 준비 단계를 사용합니다."
                TextWrapping="Wrap"
                Classes="muted" />
          </StackPanel>
        </Expander>
      </StackPanel>
    </ScrollViewer>

    <Button
        Grid.Row="1"
        Classes="primary"
        Margin="0,18,0,0"
        MinHeight="48"
        Content="서비스 열기"
        Command="{Binding LaunchCommand}"
        IsEnabled="{Binding CanLaunch}"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Center"
        AutomationProperties.AutomationId="Catalog.Launch"
        AutomationProperties.Name="선택한 서비스 열기" />
  </Grid>
</UserControl>
