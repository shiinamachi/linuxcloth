<UserControl
    x:Class="LinuxCloth.Desktop.Controls.ServiceDetails"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:localization="using:LinuxCloth.Desktop.Localization">
  <Grid RowDefinitions="*,Auto">
    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="14">
        <TextBlock
            Text="{Binding [Catalog.Details.Title], Source={x:Static localization:UiStrings.Instance}}"
            Classes="section-title" />

        <Grid ColumnDefinitions="96,*" ColumnSpacing="12">
          <Border Classes="logo-frame" Width="88" Height="88" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Image Source="{Binding SelectedService.Image}" Stretch="Uniform" />
          </Border>
          <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
            <TextBlock
                Text="{Binding SelectedService.DisplayName}"
                Classes="dialog-title"
                TextWrapping="Wrap"
                TextTrimming="CharacterEllipsis" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Classes="badge-success" IsVisible="{Binding SelectedService.IsVerified}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <PathIcon
                      Width="12"
                      Height="12"
                      Foreground="{DynamicResource SuccessBrush}"
                      Data="{StaticResource IconCheck}"
                      VerticalAlignment="Center" />
                  <TextBlock
                      Text="{Binding SelectedService.CompatibilityLabel}"
                      Classes="meta"
                      Foreground="{DynamicResource SuccessBrush}"
                      VerticalAlignment="Center" />
                </StackPanel>
              </Border>
              <Border Classes="badge-warning" IsVisible="{Binding SelectedService.IsPartial}">
                <TextBlock
                    Text="{Binding SelectedService.CompatibilityLabel}"
                    Classes="meta"
                    Foreground="{DynamicResource WarningBrush}" />
              </Border>
              <Border Classes="badge-danger" IsVisible="{Binding SelectedService.IsBlocked}">
                <TextBlock
                    Text="{Binding SelectedService.CompatibilityLabel}"
                    Classes="meta"
                    Foreground="{DynamicResource DangerBrush}" />
              </Border>
              <Border Classes="badge-neutral" IsVisible="{Binding SelectedService.IsUnknown}">
                <TextBlock Text="{Binding SelectedService.CompatibilityLabel}" Classes="meta" />
              </Border>
              <TextBlock
                  Text="{Binding SelectedService.Category}"
                  Classes="caption"
                  VerticalAlignment="Center" />
            </StackPanel>
          </StackPanel>
        </Grid>

        <TextBlock
            Text="{Binding SelectedService.CompatibilityDescription}"
            TextWrapping="Wrap"
            Classes="caption" />

        <Border Classes="notice-warning">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <PathIcon
                Width="16"
                Height="16"
                Foreground="{DynamicResource WarningBrush}"
                Data="{StaticResource IconAlert}"
                VerticalAlignment="Top"
                Margin="0,1,0,0" />
            <TextBlock
                Grid.Column="1"
                Text="{Binding [Catalog.Details.DeleteNotice], Source={x:Static localization:UiStrings.Instance}}"
                TextWrapping="Wrap"
                Classes="caption warning"
                FontWeight="SemiBold" />
          </Grid>
        </Border>

        <StackPanel Spacing="6">
          <TextBlock
              Text="{Binding [Catalog.WindowsEnvironment], Source={x:Static localization:UiStrings.Instance}}"
              FontWeight="SemiBold"
              Classes="caption" />
          <ComboBox
              ItemsSource="{Binding Images}"
              SelectedItem="{Binding SelectedImage}"
              HorizontalAlignment="Stretch"
              AutomationProperties.AutomationId="Catalog.Details.WindowsEnvironment"
              AutomationProperties.Name="{Binding [Catalog.Details.EnvironmentName], Source={x:Static localization:UiStrings.Instance}}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon
                      Width="14"
                      Height="14"
                      Data="{StaticResource IconDesktop}"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      VerticalAlignment="Center" />
                  <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </StackPanel>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button
              IsVisible="{Binding !HasImages}"
              Classes="secondary"
              Content="{Binding [Catalog.Details.PrepareEnvironment], Source={x:Static localization:UiStrings.Instance}}"
              Click="OnOpenSetup"
              AutomationProperties.AutomationId="Catalog.Details.PrepareWindowsEnvironment"
              HorizontalAlignment="Left" />
        </StackPanel>

        <Expander
            Classes="technical"
            Header="{Binding [Catalog.TechnicalDetails], Source={x:Static localization:UiStrings.Instance}}"
            AutomationProperties.AutomationId="Catalog.Details.TechnicalDetails">
          <StackPanel Spacing="8" Margin="0,8,0,0">
            <StackPanel Spacing="2">
              <TextBlock
                  Text="{Binding [Catalog.Details.EnglishName], Source={x:Static localization:UiStrings.Instance}}"
                  Classes="meta" />
              <TextBlock Text="{Binding SelectedService.EnglishDisplayName}" TextWrapping="Wrap" Classes="caption" />
            </StackPanel>
            <StackPanel Spacing="2">
              <TextBlock
                  Text="{Binding [Catalog.Details.LaunchConfig], Source={x:Static localization:UiStrings.Instance}}"
                  Classes="meta" />
              <TextBlock Text="{Binding SelectedService.PackageSummary}" TextWrapping="Wrap" Classes="caption" />
            </StackPanel>
            <TextBlock
                IsVisible="{Binding SelectedService.HasCustomBootstrap}"
                Text="{Binding [Catalog.Details.CustomBootstrap], Source={x:Static localization:UiStrings.Instance}}"
                TextWrapping="Wrap"
                Classes="caption" />
            <TextBlock Text="{Binding SelectedService.Url}" Classes="meta mono" TextWrapping="Wrap" />
          </StackPanel>
        </Expander>
      </StackPanel>
    </ScrollViewer>

    <Button
        Grid.Row="1"
        Classes="primary"
        Margin="0,16,0,0"
        MinHeight="40"
        Content="{Binding [Catalog.Details.Launch], Source={x:Static localization:UiStrings.Instance}}"
        Command="{Binding LaunchCommand}"
        IsEnabled="{Binding CanLaunch}"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Center"
        AutomationProperties.AutomationId="Catalog.Launch"
        AutomationProperties.Name="{Binding [Catalog.Details.LaunchName], Source={x:Static localization:UiStrings.Instance}}" />
  </Grid>
</UserControl>
